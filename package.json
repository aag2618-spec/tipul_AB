  "scripts": {
    "dev": "next dev",
    "build": "rm -rf .next && prisma generate && node --max-old-space-size=4096 ./node_modules/.bin/next build",
    "db:push": "prisma db push",
    "start:prod": "prisma db push && (prisma db execute --file=prisma/sql/session-time-constraint.sql || true) && (prisma db execute --file=prisma/sql/chat-attachment-path-index.sql || true) && next start",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "save-logo-preview": "node scripts/save-logo-preview-to-downloads.mjs",
