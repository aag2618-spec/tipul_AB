// Prisma schema for Therapy Practice Management System
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== Authentication ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== Core Models ====================

enum Role {
  USER
  MANAGER // משתמש עם הרשאות ניהול
  ADMIN
  CLINIC_OWNER // בעל/ת קליניקה רב-מטפלים — רואה את כל המטפלים והמזכירות בארגון
  CLINIC_SECRETARY // מזכיר/ה בקליניקה — לפי secretaryPermissions, חסום מתוכן קליני
}

// תפקיד בתוך הקליניקה — relevant only when User.organizationId != null.
enum ClinicRole {
  OWNER
  THERAPIST
  SECRETARY
}

enum DepartureStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum DepartureChoice {
  UNDECIDED
  STAY_WITH_CLINIC
  FOLLOW_THERAPIST
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  license       String?
  role          Role      @default(USER)
  isBlocked     Boolean   @default(false)
  // סיבת חסימה — null אם isBlocked=false. ערכים: DEBT | TOS_VIOLATION | MANUAL.
  // משמש את ה-webhooks לאוטו-שחרור: רק DEBT משתחרר אוטומטית בתשלום מוצלח;
  // TOS_VIOLATION ו-MANUAL נשארים חסומים עד החלטה ידנית של אדמין.
  blockReason   String?
  blockedAt     DateTime?
  blockedBy     String? // userId של האדמין שחסם; null אם נחסם אוטומטית (cron / system)

  // Two-Factor Authentication (2FA) — נאכף בקוד רק לאנשי צוות (USER/MANAGER/ADMIN)
  twoFactorEnabled       Boolean   @default(true)
  lastLoginAt            DateTime?
  lastActivityAt         DateTime? // מתי הייתה הפעולה האחרונה — בסיס לחישוב 3 שעות חוסר פעילות
  defaultSessionDuration Int       @default(50) // משך פגישה סטנדרטית בדקות
  defaultSessionPrice    Decimal?  @db.Decimal(10, 2) // מחיר ברירת מחדל לפגישה

  // AI & Billing Settings
  aiTier                AITier   @default(ESSENTIAL) // Essential, Pro, Enterprise
  therapeuticApproaches String[] @default([]) // Array of approaches: ["CBT", "Psychodynamic", etc.]
  approachDescription   String?  @db.Text // Custom description for eclectic approach
  analysisStyle         String   @default("professional") // professional, practical, emotional
  aiTone                String   @default("formal") // formal, warm, direct
  customAIInstructions  String?  @db.Text // Custom instructions for AI

  // Billing
  stripeCustomerId      String?            @unique // Stripe customer ID
  stripeSubscriptionId  String?            @unique // Stripe subscription ID
  subscriptionStatus    SubscriptionStatus @default(ACTIVE)
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  trialEndsAt           DateTime?

  // Email verification
  emailVerificationToken   String? // טוקן אימות מייל
  emailVerificationExpires DateTime? // תפוגת טוקן אימות

  // Trial AI usage limit
  trialAiCostLimit Decimal @default(5) @db.Decimal(10, 2) // תקרת עלות AI בניסיון (₪)
  trialAiUsedCost  Decimal @default(0) @db.Decimal(10, 4) // עלות AI שנוצלה בניסיון

  // Free Subscription (מנוי חינם - ניתן ע"י מנהל)
  isFreeSubscription        Boolean   @default(false)
  freeSubscriptionNote      String? // הערה למה ניתן חינם
  freeSubscriptionGrantedAt DateTime? // מתי ניתן

  // Usage limits
  maxActiveClients Int  @default(40) // Maximum active clients allowed
  userNumber       Int? @unique // מספר משתמש ייחודי (1001+)

  // ==================== Clinic Multi-Tenancy ====================
  // null = מטפל עצמאי (התנהגות קיימת, ללא שינוי).
  // ערך = שייך לארגון/קליניקה רב-מטפלים. clinicRole חייב להיות מוגדר.
  organizationId       String?
  organization         Organization? @relation("OrgMembers", fields: [organizationId], references: [id], onDelete: SetNull)
  clinicRole           ClinicRole? // OWNER/THERAPIST/SECRETARY — null אם organizationId=null.
  // מטריצת הרשאות מזכירה — רלוונטי רק ל-clinicRole=SECRETARY.
  // Shape: { canViewPayments, canIssueReceipts, canSendReminders, canCreateClient, canViewDebts, canViewStats }
  // NOTE: גישה לתוכן קליני (סיכומים/אבחנות/AI/הקלטות) חסומה קשיחות בקוד — לא ניתנת לעריכה דרך השדה הזה.
  secretaryPermissions Json?

  // Business & Receipt Settings (הגדרות עסק וקבלות)
  businessType       BusinessType     @default(NONE) // סוג עסק
  businessName       String? // שם העסק
  businessIdNumber   String? // ת.ז./ח.פ./מספר עוסק — חובה חוקית לחשבונית מס (LICENSED)
  businessPhone      String? // טלפון עסקי
  businessAddress    String? // כתובת העסק
  // שיטת חשבונאות (CASH = מקבל-תשלום: חשבונית מוצאת בעת תשלום;
  // ACCRUAL = מצטבר: חשבונית מס בעת הסכם, קבלה בעת תשלום — שני מסמכים).
  // עוסק מורשה במחזור 50K+ עובר אוטומטית למצטבר. שדה זה משפיע על document type
  // שנשלח ל-Cardcom (ב-CASH=TaxInvoiceAndReceipt; ב-ACCRUAL נדרשת זרימה דו-שלבית).
  accountingMethod   AccountingMethod @default(CASH)
  nextReceiptNumber  Int              @default(1) // מספר הקבלה הבא
  receiptDefaultMode ReceiptMode      @default(ASK) // ברירת מחדל לקבלות

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts               Account[]
  sessions               Session[]
  clients                Client[]
  therapySessions        TherapySession[]
  documents              Document[]
  notifications          Notification[]
  tasks                  Task[]
  notificationSettings   NotificationSetting[]
  recurringPatterns      RecurringPattern[]
  intakeTemplates        IntakeTemplate[]
  apiUsageLogs           ApiUsageLog[]
  subscriptionPayments   SubscriptionPayment[]
  reviewedCancellations  CancellationRequest[]
  communicationLogs      CommunicationLog[]
  communicationSetting   CommunicationSetting?
  couponUsages           CouponUsage[]
  questionnaireResponses QuestionnaireResponse[]
  intakeQuestionnaires   IntakeQuestionnaire[]   @relation("intakeQuestionnaires")
  passwordResets         PasswordReset[]
  smsSettings            SMSSettings?
  consentForms           ConsentForm[]
  insurerSettings        InsurerSettings?
  insurerReports         InsurerReport[]
  billingProviders       BillingProvider[]
  aiUsageStats           AIUsageStats?
  sessionPreps           SessionPrep[]

  // Online Booking
  bookingSettings BookingSettings?

  // AI Insights Relations
  aiInsights       AIInsight[]
  therapeuticGoals TherapeuticGoal[]
  emotionLogs      EmotionLog[]
  termsAcceptances TermsAcceptance[]

  // AI Analysis Relations
  questionnaireAnalyses QuestionnaireAnalysis[]
  sessionAnalyses       SessionAnalysis[]
  monthlyUsages         MonthlyUsage[]
  adminAuditLogs        AdminAuditLog[]         @relation("auditAdmin")

  // Support Tickets (פניות ותמיכה)
  supportTickets         SupportTicket[]     @relation("ticketUser")
  supportResponses       SupportResponse[]
  supportTicketsAssigned SupportTicket[]     @relation("ticketAssigned")
  supportNotesAuthored   SupportTicketNote[] @relation("noteAuthor")

  // Admin — undo/redo of audit actions (Stage 1.7)
  adminAuditLogsReverted AdminAuditLog[] @relation("auditReverted")

  // Packages — bank purchases granted manually by admin
  packagesGranted  UserPackagePurchase[] @relation("packageGrantedBy")
  packagePurchases UserPackagePurchase[] @relation("packageUser")

  // Site Settings — admin who last updated a global setting
  siteSettingsUpdated SiteSetting[] @relation("SiteSettingUpdater")

  // Cardcom relations
  cardcomTransactions         CardcomTransaction[]    @relation("CardcomTxUser")
  savedCardTokens             SavedCardToken[]        @relation("SavedCardTokenUser")
  subscriberTokens            SavedCardToken[]        @relation("SavedCardTokenSubscriber")
  cardcomInvoicesAsSubscriber CardcomInvoice[]        @relation("CardcomInvoiceSubscriber")
  cardcomInvoicesAsIssuer     CardcomInvoice[]        @relation("CardcomInvoiceIssuer")
  orphanCardcomDocuments      OrphanCardcomDocument[] @relation("OrphanCardcomUser")

  // 2FA codes
  twoFactorCodes TwoFactorCode[]

  // ==================== Clinic relations (inverse) ====================
  ownedOrganization        Organization?        @relation("OrgOwner")
  customContractsCreated   CustomContract[]     @relation("ContractCreator")
  clientTransfersPerformed ClientTransferLog[]  @relation("TransferPerformer")
  departureInitiated       TherapistDeparture[] @relation("DepartingTherapist")
}

// ==================== AI Tiers ====================

enum AITier {
  ESSENTIAL // 117₪ - ללא AI
  PRO // 145₪ - Gemini 2.0 Flash (תמציתי) - מוצג כ"מקצועי" בממשק
  ENTERPRISE // 220₪ - Gemini 2.0 Flash (מפורט עם גישות) - מוצג כ"ארגוני" בממשק
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  PAUSED
}

// ==================== Admin Alerts System ====================

model AdminAlert {
  id       String         @id @default(cuid())
  type     AdminAlertType
  priority AlertPriority  @default(MEDIUM)
  status   AlertStatus    @default(PENDING)

  // Alert details
  title   String
  message String @db.Text

  // Related entities (optional)
  userId String?

  // Action tracking
  actionRequired String? // מה צריך לעשות
  actionTaken    String?   @db.Text // מה נעשה
  resolvedAt     DateTime?
  resolvedBy     String? // Admin ID who resolved

  // Scheduling for reminders
  scheduledFor DateTime? // מתי להציג/לשלוח
  emailSent    Boolean   @default(false)
  emailSentAt  DateTime?

  // Metadata
  metadata Json? // Additional data (payment IDs, amounts, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([userId])
  @@index([scheduledFor])
  @@index([priority, status])
}

enum AdminAlertType {
  PAYMENT_DUE // תשלום קרב
  PAYMENT_OVERDUE // תשלום באיחור
  PAYMENT_FAILED // תשלום נכשל
  SUBSCRIPTION_EXPIRING // מנוי עומד לפוג
  SUBSCRIPTION_EXPIRED // מנוי פג
  HIGH_AI_USAGE // שימוש גבוה ב-AI
  NEW_USER // משתמש חדש נרשם
  USER_BLOCKED // משתמש נחסם
  TIER_CHANGE_REQUEST // בקשה לשינוי תוכנית
  MANUAL_REMINDER // תזכורת ידנית
  SYSTEM // התראת מערכת
  SUPPORT_TICKET // פנייה לתמיכה
  // Stage 1.7 — alerts חדשים ל-observability
  CREDIT_CONSUMPTION_FAILED // consumeSms/AI — QUOTA_EXHAUSTED או retry exhausted
  IDEMPOTENCY_REPLAY_OF_FAILURE // בקשה חוזרת עם idempotency-key של שגיאת 5xx
  SERIALIZATION_RETRY_EXHAUSTED // retry על 40001/40P01 נגמר בלי הצלחה
}

enum AlertPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AlertStatus {
  PENDING // טרם טופל
  IN_PROGRESS // בטיפול
  RESOLVED // טופל
  DISMISSED // נדחה
  SNOOZED // נדחה לזמן מאוחר
}

// ==================== Password Reset ====================

model PasswordReset {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Client {
  id                  String       @id @default(cuid())
  firstName           String?
  lastName            String?
  name                String
  phone               String?
  email               String?
  birthDate           DateTime?
  address             String?
  status              ClientStatus @default(ACTIVE)
  isQuickClient       Boolean      @default(false) // פונה מזדמן — נוצר מהיומן עם מינימום פרטים
  defaultSessionPrice Decimal?     @db.Decimal(10, 2)
  creditBalance       Decimal      @default(0) @db.Decimal(10, 2) // יתרת קרדיט
  medicalHistory      Json?
  notes               String?      @db.Text
  initialDiagnosis    String?      @db.Text
  intakeNotes         String?      @db.Text

  // AI Settings - client-specific therapeutic approaches (override therapist defaults)
  therapeuticApproaches String[] @default([]) // Override therapist's default approaches
  approachNotes         String?  @db.Text // Special notes about therapeutic approach for this client
  culturalContext       String?  @db.Text // Cultural context for AI analysis sensitivity

  // Comprehensive AI analysis (saved from "all summaries" page)
  comprehensiveAnalysis   String?   @db.Text
  comprehensiveAnalysisAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  therapistId String
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  // Clinic multi-tenancy — null = מטופל של מטפל עצמאי (התנהגות קיימת).
  // ערך = משתייך לקליניקה (חייב להיות זהה ל-organizationId של המטפל).
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  therapySessions        TherapySession[]
  payments               Payment[]
  documents              Document[]
  recordings             Recording[]
  recurringPatterns      RecurringPattern[]
  cancellationRequests   CancellationRequest[]
  communicationLogs      CommunicationLog[]
  questionnaireResponses QuestionnaireResponse[]
  intakeResponses        IntakeResponse[]        @relation("intakeResponses")
  consentForms           ConsentForm[]

  // AI Analysis Relations
  questionnaireAnalyses QuestionnaireAnalysis[]

  // AI Insights Relations
  aiInsights       AIInsight[]
  therapeuticGoals TherapeuticGoal[]
  emotionLogs      EmotionLog[]

  // Cardcom — saved tokens for recurring billing
  savedCardTokens SavedCardToken[]

  // Cardcom — invoices issued TO this client (USER tenant)
  cardcomInvoicesReceived CardcomInvoice[] @relation("CardcomInvoiceRecipient")

  // Clinic departure flow — בחירות שמטופל זה עשה כשמטפלת עוזבת
  departureChoices ClientDepartureChoice[]

  @@index([organizationId])
  @@index([organizationId, therapistId])
}

enum ClientStatus {
  ACTIVE
  WAITING
  INACTIVE
  ARCHIVED
}

model TherapySession {
  id          String        @id @default(cuid())
  startTime   DateTime
  endTime     DateTime
  status      SessionStatus @default(SCHEDULED)
  type        SessionType   @default(IN_PERSON)
  price       Decimal       @db.Decimal(10, 2)
  topic       String?       @db.Text // נושא הפגישה (חובה לפגישת ייעוץ)
  notes       String?       @db.Text
  location    String?
  isRecurring Boolean       @default(false)
  skipSummary Boolean       @default(false) // האם להסתיר מרשימת "ללא סיכום"

  // Cancellation fields
  cancellationReason      String?   @db.Text
  cancellationRequestedAt DateTime?
  cancelledAt             DateTime?
  cancelledBy             String? // 'CLIENT', 'THERAPIST', 'SYSTEM'

  // Google Calendar sync
  googleEventId String?

  // Shabbat outbox — מסומן true אם הפגישה נוצרה בשבת/חג ושליחת ההודעות נדחתה
  pendingConfirmationEmail    Boolean @default(false) // מייל אישור ללקוח
  pendingConfirmationSms      Boolean @default(false) // SMS אישור ללקוח
  pendingTherapistNotifyEmail Boolean @default(false) // מייל התראה למטפל

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  therapistId String
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  sessionNote          SessionNote?
  payment              Payment?
  recordings           Recording[]
  cancellationRequests CancellationRequest[]
  communicationLogs    CommunicationLog[]
  smsReminders         SMSReminder[]
  insurerReports       InsurerReport[]

  // AI Analysis
  sessionAnalysis SessionAnalysis?
  emotionLogs     EmotionLog[]

  // Clinic multi-tenancy
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, startTime])
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  PENDING_CANCELLATION
  PENDING_APPROVAL
  NO_SHOW
}

enum SessionType {
  IN_PERSON
  ONLINE
  PHONE
  BREAK
}

model SessionNote {
  id         String   @id @default(cuid())
  content    String   @db.Text
  isPrivate  Boolean  @default(false)
  aiAnalysis Json? // Stores AI analysis of the note
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessionId String         @unique
  session   TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ==================== Recording & AI ====================

model Recording {
  id              String          @id @default(cuid())
  audioUrl        String
  durationSeconds Int
  type            RecordingType
  status          RecordingStatus @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  sessionId String?
  session   TherapySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  transcription Transcription?
}

enum RecordingType {
  INTAKE
  SESSION
}

enum RecordingStatus {
  PENDING
  TRANSCRIBING
  TRANSCRIBED
  ANALYZED
  ERROR
}

model Transcription {
  id         String   @id @default(cuid())
  content    String   @db.Text
  language   String   @default("he")
  confidence Float?
  timestamps Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  recordingId String    @unique
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)

  analysis Analysis?
}

model Analysis {
  id               String   @id @default(cuid())
  summary          String   @db.Text
  keyTopics        Json?
  emotionalMarkers Json?
  recommendations  Json?
  nextSessionNotes String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transcriptionId String        @unique
  transcription   Transcription @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)
}

// ==================== Payments ====================

model Payment {
  id             String        @id @default(cuid())
  amount         Decimal       @db.Decimal(10, 2) // הסכום ששולם בפועל
  expectedAmount Decimal?      @db.Decimal(10, 2) // הסכום המלא שהיה צריך להשתלם
  paymentType    PaymentType   @default(FULL) // סוג התשלום
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  receiptUrl     String?
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Receipt tracking
  receiptNumber String? // מספר קבלה (לעוסק פטור)
  hasReceipt    Boolean @default(false) // האם הוצאה קבלה

  // Cardcom decline tracking — surfaced to the therapist UI as "ניסיון אחרון נכשל"
  lastDeclineReason String?   @db.Text
  lastDeclineAt     DateTime?

  // Currency — ILS today; column exists so multi-currency work in V2 doesn't
  // require a row-by-row migration on production data.
  currency String @default("ILS")

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  sessionId String?         @unique
  session   TherapySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  // Parent-Child relation for partial payments
  parentPaymentId String?
  parentPayment   Payment?  @relation("PaymentChildren", fields: [parentPaymentId], references: [id], onDelete: Cascade)
  childPayments   Payment[] @relation("PaymentChildren")

  // Cardcom — transactions and invoices linked to this payment
  cardcomTransactions CardcomTransaction[]
  cardcomInvoices     CardcomInvoice[]

  // Clinic multi-tenancy
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([parentPaymentId])
  @@index([clientId])
  @@index([status])
  @@index([clientId, status])
  @@index([hasReceipt])
  @@index([organizationId])
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  BANK_TRANSFER
  CHECK
  CREDIT
  OTHER
}

// Business type for receipt handling
enum BusinessType {
  NONE // לא רוצה קבלות
  EXEMPT // עוסק פטור - קבלות פנימיות
  LICENSED // עוסק מורשה - מחובר למערכת חיצונית
}

// Israeli accounting method:
//   CASH    — מקבל-תשלום: invoice issued at payment time (most freelancers).
//   ACCRUAL — מצטבר: tax invoice at agreement, separate receipt at payment.
enum AccountingMethod {
  CASH
  ACCRUAL
}

// Default receipt mode
enum ReceiptMode {
  ALWAYS // תמיד להוציא קבלה
  ASK // לשאול בכל תשלום
  NEVER // לעולם לא
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentType {
  FULL // תשלום מלא
  PARTIAL // תשלום חלקי
  ADVANCE // תשלום מראש (קרדיט)
}

// ==================== Documents ====================

model Document {
  id        String       @id @default(cuid())
  name      String
  type      DocumentType
  fileUrl   String
  signed    Boolean      @default(false)
  signedAt  DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  therapistId String
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Clinic multi-tenancy — FK bareback (ללא @relation). null = מטפל עצמאי.
  organizationId String?

  @@index([organizationId])
}

enum DocumentType {
  CONSENT_FORM
  INTAKE_FORM
  TREATMENT_PLAN
  REPORT
  OTHER
}

// ==================== Notifications & Tasks ====================

model Notification {
  id           String             @id @default(cuid())
  type         NotificationType
  title        String
  content      String             @db.Text
  status       NotificationStatus @default(PENDING)
  scheduledFor DateTime?
  sentAt       DateTime?
  readAt       DateTime?
  createdAt    DateTime           @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  MORNING_SUMMARY
  EVENING_SUMMARY
  PENDING_TASKS
  PAYMENT_REMINDER
  SESSION_REMINDER
  EMAIL_SENT
  EMAIL_RECEIVED
  CANCELLATION_REQUEST
  BOOKING_REQUEST
  CUSTOM
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  DISMISSED
}

model Task {
  id              String     @id @default(cuid())
  type            TaskType
  title           String
  description     String?    @db.Text
  status          TaskStatus @default(PENDING)
  priority        Priority   @default(MEDIUM)
  dueDate         DateTime?
  reminderAt      DateTime?
  relatedEntityId String?
  relatedEntity   String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TaskType {
  WRITE_SUMMARY
  COLLECT_PAYMENT
  SIGN_DOCUMENT
  SCHEDULE_SESSION
  REVIEW_TRANSCRIPTION
  FOLLOW_UP
  CUSTOM
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISMISSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model NotificationSetting {
  id                 String   @id @default(cuid())
  channel            String
  enabled            Boolean  @default(true)
  eveningTime        String? // Format: "HH:mm"
  morningTime        String? // Format: "HH:mm"
  debtThresholdDays  Int      @default(30)
  monthlyReminderDay Int? // 1-31, day of month for payment reminder
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== Recurring Sessions ====================

model RecurringPattern {
  id        String   @id @default(cuid())
  dayOfWeek Int // 0-6 (Sunday-Saturday)
  time      String // Format: "HH:mm"
  duration  Int      @default(50) // minutes
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

// ==================== Intake Templates ====================

model IntakeTemplate {
  id        String   @id @default(cuid())
  name      String
  questions Json // Array of question objects
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== Admin: API Usage Logging ====================

model ApiUsageLog {
  id           String   @id @default(cuid())
  endpoint     String // e.g., "/api/transcribe", "/api/analyze"
  method       String // e.g., "POST"
  tokensUsed   Int? // Estimated tokens used for AI calls
  cost         Decimal? @db.Decimal(10, 4) // Estimated cost in dollars
  success      Boolean  @default(true)
  errorMessage String?  @db.Text
  durationMs   Int? // Request duration in milliseconds
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== Admin: Subscription Payments ====================

model SubscriptionPayment {
  id          String                    @id @default(cuid())
  amount      Decimal                   @db.Decimal(10, 2)
  currency    String                    @default("ILS")
  status      SubscriptionPaymentStatus @default(PENDING)
  description String?
  invoiceUrl  String?
  periodStart DateTime?
  periodEnd   DateTime?
  paidAt      DateTime?
  // Stage 1.7 — שיטת תשלום (ידני: מזומן/העברה/צ'ק, אוטומטי: אשראי דרך קארדקום)
  method      PaymentMethod?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Cardcom — auto-charge fields (V2: cron) + relations
  autoChargeEnabled   Boolean              @default(false)
  savedCardTokenId    String?
  savedCardToken      SavedCardToken?      @relation(fields: [savedCardTokenId], references: [id], onDelete: SetNull)
  nextChargeAt        DateTime?
  cardcomTransactions CardcomTransaction[]
  cardcomInvoices     CardcomInvoice[]
}

enum SubscriptionPaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

// ==================== Terms Acceptance Log ====================
// רשומות הוכחה חוקיות - לעולם לא למחוק!

model TermsAcceptance {
  id String @id @default(cuid())

  // מי אישר
  userId    String
  user      User    @relation(fields: [userId], references: [id]) // NO cascade - שומר הוכחה גם אם המשתמש נמחק
  userEmail String // מייל בזמן האישור (backup אם המשתמש ישנה מייל)
  userName  String? // שם בזמן האישור

  // מה אושר
  termsVersion    String @default("1.0") // גרסת התנאים שאושרו
  termsType       String // SUBSCRIPTION_TERMS | PRIVACY_POLICY | CANCELLATION_POLICY
  acceptedContent String @db.Text // תקציר התנאים שאושרו

  // הקשר הפעולה
  action        String // SUBSCRIPTION_CREATE | SUBSCRIPTION_UPGRADE | SUBSCRIPTION_RENEW
  planSelected  String? // ESSENTIAL | PRO | ENTERPRISE
  billingMonths Int? // 1 | 3 | 6 | 12
  amountAgreed  Decimal? @db.Decimal(10, 2) // הסכום שהוסכם

  // פרטי זיהוי (הוכחה חוקית)
  ipAddress String? // כתובת IP
  userAgent String? @db.Text // דפדפן/מכשיר

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([termsType])
}

// ==================== Cancellation Requests ====================

model CancellationRequest {
  id         String                    @id @default(cuid())
  reason     String?                   @db.Text
  status     CancellationRequestStatus @default(PENDING)
  adminNotes String?                   @db.Text
  reviewedAt DateTime?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  sessionId String
  session   TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  reviewedById String?
  reviewedBy   User?   @relation(fields: [reviewedById], references: [id], onDelete: SetNull)
}

enum CancellationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== Communication Log ====================

model CommunicationLog {
  id           String               @id @default(cuid())
  type         CommunicationType
  channel      CommunicationChannel @default(EMAIL)
  recipient    String
  subject      String?
  content      String               @db.Text
  status       CommunicationStatus  @default(PENDING)
  errorMessage String?              @db.Text
  sentAt       DateTime?
  createdAt    DateTime             @default(now())

  // Email tracking fields
  messageId   String? // Resend message ID for tracking replies
  inReplyTo   String? // ID of the message this is replying to
  isRead      Boolean   @default(false) // Has therapist read this reply?
  readAt      DateTime? // When was it read?
  attachments Json? // [{id, filename, contentType, size, resendEmailId}]

  sessionId String?
  session   TherapySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Clinic multi-tenancy — FK bareback. null = מטפל עצמאי.
  organizationId String?

  @@index([organizationId])
}

enum CommunicationType {
  SESSION_CONFIRMATION
  REMINDER_24H
  REMINDER_2H
  CANCELLATION_REQUEST_TO_CLIENT
  CANCELLATION_REQUEST_TO_THERAPIST
  CANCELLATION_APPROVED
  CANCELLATION_REJECTED
  CANCELLATION_BY_THERAPIST
  SESSION_CHANGED
  NO_SHOW_NOTIFICATION
  BOOKING_APPROVED
  BOOKING_REJECTED
  DEBT_REMINDER
  CUSTOM
  INCOMING_EMAIL
  INCOMING_SMS
  // Subscription / Trial reminders — נוספו עבור dedup חסימת שבת
  SUBSCRIPTION_REMINDER_7D
  SUBSCRIPTION_REMINDER_3D
  SUBSCRIPTION_REMINDER_1D
  TRIAL_REMINDER_7D
  TRIAL_REMINDER_3D
  TRIAL_REMINDER_2D
  TRIAL_EXPIRED
}

enum CommunicationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum CommunicationStatus {
  PENDING
  SENT
  FAILED
  RECEIVED
  DISMISSED // כשל שסומן כטופל ע"י המשתמש
}

// ==================== Communication Settings ====================

model CommunicationSetting {
  id String @id @default(cuid())

  // Session notifications
  sendConfirmationEmail Boolean @default(true)
  send24hReminder       Boolean @default(true)
  send2hReminder        Boolean @default(false)
  customReminderEnabled Boolean @default(false)
  customReminderHours   Int     @default(2)

  // Cancellation policy
  allowClientCancellation Boolean @default(true)
  minCancellationHours    Int     @default(24)

  // Debt reminders
  sendDebtReminders      Boolean @default(false) // שליחת תזכורות חוב אוטומטיות
  debtReminderDayOfMonth Int     @default(1) // יום בחודש (1-28)
  debtReminderMinAmount  Decimal @default(50) // סכום מינימלי לשליחת תזכורת

  // Payment receipts
  sendPaymentReceipt     Boolean @default(false) // שליחת קבלה אוטומטית אחרי תשלום
  sendReceiptToClient    Boolean @default(true) // שלח קבלה למטופל
  sendReceiptToTherapist Boolean @default(false) // שלח עותק למטפל
  receiptEmailTemplate   String? @db.Text // תבנית מותאמת אישית לקבלה

  // Email customization
  paymentInstructions String? @db.Text // הוראות תשלום מותאמות אישית
  paymentLink         String? // קישור לתשלום ישיר (ביט/פייבוקס וכו')
  emailSignature      String? @db.Text // חתימה אישית
  logoUrl             String? // URL ללוגו
  customGreeting      String? // ברכת פתיחה מותאמת (למשל: "היי {שם}, מקווה שהשבוע עבר בטוב")
  customClosing       String? // ברכת סיום מותאמת (למשל: "תודה ומחכה לראותך")
  businessHours       String? // שעות פעילות (טקסט חופשי)

  // ── SMS toggles (per-type, independent from email) ──
  sendBookingConfirmationSMS Boolean @default(true) // אישור הזמנה ב-SMS
  sendReminder24hSMS         Boolean @default(true) // תזכורת 24 שעות ב-SMS
  sendReminderCustomSMS      Boolean @default(false) // תזכורת מותאמת ב-SMS
  sendCancellationSMS        Boolean @default(true) // הודעת ביטול ב-SMS
  sendSessionChangeSMS       Boolean @default(true) // הודעת שינוי פגישה ב-SMS
  sendNoShowSMS              Boolean @default(false) // הודעת "לא הגיע" ב-SMS
  sendDebtReminderSMS        Boolean @default(false) // תזכורת חוב ב-SMS

  // ── Email toggles for new types ──
  sendCancellationEmail  Boolean @default(true) // הודעת ביטול במייל
  sendSessionChangeEmail Boolean @default(true) // הודעת שינוי פגישה במייל
  sendNoShowEmail        Boolean @default(false) // הודעת "לא הגיע" במייל

  // ── SMS quota management ──
  smsMonthlyQuota   Int       @default(200) // מכסה חודשית
  smsMonthlyUsage   Int       @default(0) // שימוש החודש
  smsQuotaResetDate DateTime? // תאריך איפוס אחרון
  smsAlertAtPercent Int       @default(80) // התראה באחוז ניצול

  // ── SMS templates (customizable per type) ──
  templateBookingConfirmSMS String? @db.Text // "שלום {שם}, ההזמנה התקבלה! פגישה ב-{תאריך} ב-{שעה}"
  templateReminder24hSMS    String? @db.Text // "שלום {שם}, תזכורת לפגישה מחר ({יום}) ב-{שעה}"
  templateReminderCustomSMS String? @db.Text // "שלום {שם}, פגישה בעוד {שעות} שעות ב-{שעה}"
  templateCancellationSMS   String? @db.Text // "שלום {שם}, הפגישה ב-{תאריך} ב-{שעה} בוטלה"
  templateSessionChangeSMS  String? @db.Text // "שלום {שם}, הפגישה הועברה ל-{תאריך} ב-{שעה}"
  templateNoShowSMS         String? @db.Text // "שלום {שם}, חבל שלא הגעת היום. ליצירת קשר: {טלפון}"
  templateDebtReminderSMS   String? @db.Text // "שלום {שם}, יש יתרה פתוחה של {סכום}. פרטים נשלחו במייל"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== Billing & Payment Integration ====================

enum BillingProviderType {
  MESHULAM // משולם - סליקה + קבלות
  ICOUNT // iCount - קבלות בלבד
  GREEN_INVOICE // חשבונית ירוקה - קבלות בלבד
  SUMIT // סאמיט - קבלות + סליקה
  PAYPLUS // PayPlus - סליקה בלבד
  CARDCOM // CardCom - סליקה בלבד
  TRANZILA // טרנזילה - סליקה בלבד
}

model BillingProvider {
  id          String              @id @default(cuid())
  provider    BillingProviderType
  displayName String // שם להצגה (למשל: "Meshulam - חשבון ראשי")

  // API Credentials (מוצפן!)
  apiKey                          String    @db.Text // ENCRYPTED
  apiSecret                       String?   @db.Text // ENCRYPTED (אופציונלי)
  webhookSecret                   String?   @db.Text // לאימות Webhooks
  // Previous webhook secret kept for `previousWebhookSecretValidUntil` so
  // rotating credentials doesn't reject in-flight retries. Set automatically
  // when `webhookSecret` is updated, expires after 24 hours.
  previousWebhookSecret           String?   @db.Text
  previousWebhookSecretValidUntil DateTime?

  // הגדרות נוספות
  isActive  Boolean @default(true)
  isPrimary Boolean @default(false) // האם זה הספק הראשי

  // הגדרות התנהגות
  settings Json? // { discreteMode: true, defaultDescription: "ייעוץ", autoSendReceipt: true }

  // מטא-דאטה
  lastSyncAt DateTime? // מתי התבצע סנכרון אחרון
  lastError  String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // קשר למשתמש
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([userId, isPrimary])
}

// ==================== Coupon System ====================

enum CouponType {
  SINGLE_USE // קופון חד-פעמי - לקוח ספציפי
  LIMITED // מוגבל למספר שימושים
  UNLIMITED // ללא הגבלה
}

model Coupon {
  id   String     @id @default(cuid())
  code String     @unique // הקוד עצמו
  name String // שם לתיאור (לנוחות ניהול)
  type CouponType @default(LIMITED)

  maxUses   Int? // מקסימום שימושים (null = ללא הגבלה)
  usedCount Int  @default(0) // כמה פעמים השתמשו

  discount  Int @default(0) // אחוז הנחה (לעתיד)
  trialDays Int @default(30) // ימי ניסיון

  validFrom  DateTime  @default(now()) // תחילת תוקף
  validUntil DateTime? // תאריך תפוגה (null = ללא תפוגה)

  isActive Boolean @default(true) // האם פעיל

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // מי השתמש בקופון
  usages CouponUsage[]
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  userId   String
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId]) // משתמש יכול להשתמש בקופון פעם אחת
}

// ==================== Questionnaires ====================

model QuestionnaireTemplate {
  id          String   @id @default(cuid())
  code        String   @unique // e.g., "BDI2", "PCL5", "HAMA"
  name        String // e.g., "מדד דיכאון בק"
  nameEn      String? // e.g., "Beck Depression Inventory"
  description String?  @db.Text
  category    String? // e.g., "דיכאון", "חרדה", "טראומה"
  testType    TestType @default(SELF_REPORT) // סוג המבחן
  questions   Json // Array of questions with options
  scoring     Json? // Scoring instructions
  stimuli     Json? // For projective tests - images/cards
  subtests    Json? // For intelligence tests - subtests
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  responses QuestionnaireResponse[]
}

enum TestType {
  SELF_REPORT // שאלון דיווח עצמי (BDI, PCL-5)
  CLINICIAN_RATED // הערכה קלינית (HAM-A)
  PROJECTIVE // מבחן השלכתי (רורשאך, TAT)
  INTELLIGENCE // מבחן אינטליגנציה (וקסלר)
  NEUROPSYCH // מבחן נוירופסיכולוגי (Bender)
  INTERVIEW // ראיון מובנה (SCID)
}

model QuestionnaireResponse {
  id          String              @id @default(cuid())
  answers     Json // Array of answers
  totalScore  Int? // Calculated total score
  subscores   Json? // Category/criterion scores
  aiAnalysis  String?             @db.Text // AI analysis of results
  status      QuestionnaireStatus @default(IN_PROGRESS)
  startedAt   DateTime            @default(now())
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  templateId String
  template   QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  therapistId String
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  // AI Analysis Relations
  questionnaireAnalyses QuestionnaireAnalysis[]

  // Clinic multi-tenancy — FK bareback. null = מטפל עצמאי.
  organizationId String?

  @@index([organizationId])
}

enum QuestionnaireStatus {
  IN_PROGRESS
  COMPLETED
  ANALYZED
}

// ==================== Intake Questionnaires (Simple) ====================

model IntakeQuestionnaire {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("intakeQuestionnaires", fields: [userId], references: [id], onDelete: Cascade)

  name        String // "תשאול ראשוני"
  description String? // תיאור קצר
  isDefault   Boolean @default(false) // ברירת מחדל?
  isActive    Boolean @default(true) // פעיל?
  questions   Json // מערך שאלות פשוטות

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses IntakeResponse[]

  @@index([userId])
  @@index([userId, isDefault])
}

model IntakeResponse {
  id         String              @id @default(cuid())
  clientId   String
  client     Client              @relation("intakeResponses", fields: [clientId], references: [id], onDelete: Cascade)
  templateId String
  template   IntakeQuestionnaire @relation(fields: [templateId], references: [id], onDelete: Cascade)

  responses Json // התשובות (key-value pairs)
  filledAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Clinic multi-tenancy — FK bareback. null = מטפל עצמאי.
  organizationId String?

  @@index([clientId])
  @@index([templateId])
  @@index([organizationId])
}

// ==================== SMS Reminders ====================

model SMSReminder {
  id           String    @id @default(cuid())
  phoneNumber  String
  message      String    @db.Text
  scheduledFor DateTime
  sentAt       DateTime?
  status       SMSStatus @default(PENDING)
  errorMessage String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessionId String
  session   TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([scheduledFor])
  @@index([status])
}

enum SMSStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model SMSSettings {
  id                  String   @id @default(cuid())
  enabled             Boolean  @default(false)
  hoursBeforeReminder Int      @default(24) // Hours before session to send reminder
  customMessage       String?  @db.Text
  sendOnWeekends      Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  therapistId String @unique
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

// ==================== Consent Forms ====================

model ConsentForm {
  id            String      @id @default(cuid())
  type          ConsentType
  title         String
  content       String      @db.Text // HTML content of the form
  isTemplate    Boolean     @default(false) // Is this a reusable template?
  signedAt      DateTime?
  signatureData String?     @db.Text // Base64 signature image
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  therapistId String
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  // Clinic multi-tenancy — FK bareback. null = מטפל עצמאי.
  organizationId String?

  @@index([type])
  @@index([clientId])
  @@index([organizationId])
}

enum ConsentType {
  TREATMENT_AGREEMENT // הסכם טיפול
  INFORMED_CONSENT // הסכמה מדעת
  CONFIDENTIALITY // הסכם סודיות
  RECORDING_CONSENT // הסכמה להקלטה
  TELEHEALTH_CONSENT // הסכמה לטיפול מרחוק
  PARENTAL_CONSENT // הסכמת הורים (קטינים)
  CUSTOM // טופס מותאם אישית
}

// ==================== Health Insurance Integration ====================

model InsurerSettings {
  id      String  @id @default(cuid())
  enabled Boolean @default(false)

  // Clalit - כללית
  clalitEnabled    Boolean @default(false)
  clalitApiKey     String?
  clalitFacilityId String?

  // Maccabi - מכבי
  maccabiEnabled    Boolean @default(false)
  maccabiApiKey     String?
  maccabiProviderId String?

  // Meuhedet - מאוחדת
  meuhedetEnabled  Boolean @default(false)
  meuhedetUsername String?
  meuhedetPassword String?

  // Leumit - לאומית
  leumitEnabled    Boolean @default(false)
  leumitApiKey     String?
  leumitClinicCode String?

  autoSubmit Boolean  @default(false) // Auto-submit reports after session
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  therapistId String @unique
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

model InsurerReport {
  id               String        @id @default(cuid())
  insurer          HealthInsurer
  reportData       String        @db.Text // JSON formatted report
  status           ReportStatus  @default(DRAFT)
  submittedAt      DateTime?
  confirmationCode String?
  errorMessage     String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  sessionId String
  session   TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  therapistId String
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([insurer])
  @@index([status])
  @@index([sessionId])
}

enum HealthInsurer {
  CLALIT
  MACCABI
  MEUHEDET
  LEUMIT
}

enum ReportStatus {
  DRAFT
  PENDING
  SUBMITTED
  CONFIRMED
  REJECTED
  ERROR
}

// ==================== AI Usage Tracking ====================

model AIUsageStats {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Current month stats
  currentMonthCalls  Int     @default(0)
  currentMonthTokens Int     @default(0)
  currentMonthCost   Decimal @default(0) @db.Decimal(10, 4)

  // Daily stats (reset every day)
  dailyCalls    Int      @default(0)
  lastResetDate DateTime @default(now())

  // All-time stats
  totalCalls Int     @default(0)
  totalCost  Decimal @default(0) @db.Decimal(10, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model SessionPrep {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientId    String
  sessionDate DateTime

  // AI Analysis content
  content         String @db.Text
  insights        Json? // Structured insights
  recommendations Json? // Structured recommendations

  // Metadata
  aiModel     String // "gpt-4o", "gpt-4o-mini", "gemini-1.5-flash"
  tokensUsed  Int
  cost        Decimal  @db.Decimal(10, 4)
  generatedAt DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([userId, sessionDate])
  @@index([clientId])
}

// ==================== Admin Global Settings ====================

model GlobalAISettings {
  id String @id @default(cuid())

  // Rate limits
  dailyLimitEssential  Int @default(0) // 0 = no AI
  dailyLimitPro        Int @default(30) // 30 calls/day
  dailyLimitEnterprise Int @default(100) // 100 calls/day

  monthlyLimitEssential  Int @default(0) // 0 = no AI
  monthlyLimitPro        Int @default(600) // 600 calls/month
  monthlyLimitEnterprise Int @default(2000) // 2000 calls/month

  // Cost controls
  maxMonthlyCostBudget Decimal @default(5000) @db.Decimal(10, 2) // Total budget cap
  alertThreshold       Decimal @default(4000) @db.Decimal(10, 2) // Alert at 80%

  // Behavior on limit exceed
  blockOnExceed      Boolean @default(false) // Block user or just alert
  alertAdminOnExceed Boolean @default(true)

  // Feature flags
  enableCache     Boolean @default(true) // Cache identical requests
  compressPrompts Boolean @default(true) // Compress long prompts

  updatedAt DateTime @updatedAt

  @@map("global_ai_settings")
}

// ==================== AI Insights System ====================

model AIInsight {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type       InsightType // Type of insight
  title      String // Short title
  content    String      @db.Text // Full content
  confidence Float // 0-1, how confident the AI is

  metadata Json? // Additional structured data

  // Caching and validity
  validUntil DateTime // When this insight expires
  isStale    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, type])
  @@index([userId, createdAt])
  @@index([validUntil])
}

enum InsightType {
  PATTERN // Behavioral patterns
  EMOTION_TREND // Emotional tracking
  GOAL_PROGRESS // Goal achievement
  TECHNIQUE_REC // Technique recommendations
  OPEN_ISSUE // Unresolved topics
  RELATIONSHIP_MAP // Key relationships
  RISK_FLAG // Warning signs
}

model TherapeuticGoal {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title    String // Goal description
  category String? // e.g., "anxiety", "depression", "relationships"

  // Progress tracking
  startValue   Int // Initial score (e.g., 8/10)
  targetValue  Int // Target score (e.g., 3/10)
  currentValue Int // Current score
  unit         String @default("scale") // "scale", "frequency", "percentage"

  // Calculated
  progress Float // Percentage progress (0-100)
  trend    String // "improving", "stable", "declining"

  // Timeline
  startDate   DateTime   @default(now())
  targetDate  DateTime?
  lastUpdated DateTime   @updatedAt
  status      GoalStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  @@index([clientId, status])
  @@index([userId])
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

model EmotionLog {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessionId String?
  session   TherapySession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Emotion data
  emotion   String // Primary emotion detected
  intensity Int // 1-10
  valence   String // "positive", "negative", "neutral"

  // Context
  context  String? @db.Text
  triggers Json? // Array of trigger keywords

  // Source
  source String @default("ai_analysis") // "ai_analysis", "manual", "questionnaire"

  recordedAt DateTime @default(now())

  @@index([clientId, recordedAt])
  @@index([userId])
}

// ==================== Questionnaire Analysis ====================

model QuestionnaireAnalysis {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Analysis type
  analysisType QuestionnaireAnalysisType

  // Single questionnaire analysis
  responseId String?
  response   QuestionnaireResponse? @relation(fields: [responseId], references: [id], onDelete: Cascade)

  // Combined analysis - multiple questionnaires
  responseIds String[] // Array of response IDs if combined analysis

  // Progress report - questionnaires + session summaries
  sessionIds String[] // Array of session IDs if progress report
  dateFrom   DateTime?
  dateTo     DateTime?

  // Analysis content
  content         String @db.Text
  insights        Json? // Structured insights
  recommendations Json? // Structured recommendations

  // Metadata
  aiModel    String // "gpt-4o", "gpt-4o-mini", "gemini-1.5-flash"
  tokensUsed Int
  cost       Decimal @db.Decimal(10, 4)

  createdAt DateTime @default(now())

  // Clinic multi-tenancy — FK bareback. null = מטפל עצמאי.
  organizationId String?

  @@index([userId, clientId])
  @@index([clientId, createdAt])
  @@index([analysisType])
  @@index([organizationId])
}

enum QuestionnaireAnalysisType {
  SINGLE // Single questionnaire
  COMBINED // All questionnaires for a client
  PROGRESS_REPORT // Questionnaires + session summaries over time
}

// ==================== Session Analysis (Detailed/Concise) ====================

model SessionAnalysis {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String         @unique
  session   TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Analysis type
  analysisType AnalysisType

  // Content
  content  String @db.Text
  insights Json? // Structured insights

  // Metadata
  aiModel    String // "gpt-4o", "gemini-1.5-flash"
  tokensUsed Int
  cost       Decimal @db.Decimal(10, 4)

  createdAt DateTime @default(now())

  // Clinic multi-tenancy — FK bareback. null = מטפל עצמאי.
  organizationId String?

  @@index([userId, sessionId])
  @@index([analysisType])
  @@index([organizationId])
}

enum AnalysisType {
  CONCISE // Short analysis (0.5 pages)
  DETAILED // Detailed analysis (2-3 pages)
}

// ==================== Tier Usage Limits ====================

model TierLimits {
  id   String @id @default(cuid())
  tier AITier @unique

  // הכנות לפגישה
  sessionPrepLimit Int @default(0) // 0 = ללא הגבלה, -1 = חסום

  // ניתוחי פגישה
  conciseAnalysisLimit  Int @default(0) // תמציתי
  detailedAnalysisLimit Int @default(0) // מפורט

  // ניתוחי שאלונים
  singleQuestionnaireLimit   Int @default(0) // שאלון בודד
  combinedQuestionnaireLimit Int @default(0) // ניתוח משולב
  progressReportLimit        Int @default(0) // דוח התקדמות

  // תיאור התוכנית
  displayNameHe String  @default("") // שם בעברית
  displayNameEn String  @default("") // שם באנגלית
  priceMonthly  Int     @default(0) // מחיר חודשי בשקלים
  description   String? @db.Text // תיאור התוכנית

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tier_limits")
}

// ==================== Admin Email Templates ====================

model AdminEmailTemplate {
  id   String            @id @default(cuid())
  type EmailTemplateType

  // Email content
  subject  String
  bodyHtml String  @db.Text
  bodyText String? @db.Text

  // Placeholders documentation
  placeholders Json? // { "{name}": "שם המשתמש", "{amount}": "סכום" }

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type])
  @@map("admin_email_templates")
}

enum EmailTemplateType {
  PAYMENT_REMINDER // תזכורת תשלום
  PAYMENT_OVERDUE // תשלום באיחור
  SUBSCRIPTION_EXPIRING // מנוי עומד לפוג
  SUBSCRIPTION_EXPIRED // מנוי פג
  WELCOME_NEW_USER // ברוך הבא
  TIER_UPGRADE // שדרוג תוכנית
  TIER_DOWNGRADE // שנמוך תוכנית
  CUSTOM // מותאם אישית
}

// ==================== Monthly Usage Tracking ====================

model MonthlyUsage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month Int // 1-12
  year  Int // 2024, 2025, etc.

  // Session Prep (daily automatic)
  sessionPrepCount Int @default(0)

  // Session Analysis
  conciseAnalysisCount  Int @default(0) // Unlimited (1 per session)
  detailedAnalysisCount Int @default(0) // Enterprise: 10/month

  // Questionnaire Analysis
  singleQuestionnaireCount   Int @default(0) // Pro: 60, Enterprise: 80
  combinedQuestionnaireCount Int @default(0) // Pro: 30, Enterprise: 40
  progressReportCount        Int @default(0) // Pro: 15, Enterprise: 20

  // Total costs
  totalCost   Decimal @default(0) @db.Decimal(10, 4)
  totalTokens Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId, year, month])
}

// ==================== System Announcements ====================

model SystemAnnouncement {
  id         String    @id @default(cuid())
  title      String
  content    String    @db.Text
  type       String    @default("info") // info, warning, success, update
  isActive   Boolean   @default(true)
  showBanner Boolean   @default(true) // show as top banner on dashboard
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  dismissals AnnouncementDismissal[]
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  dismissedAt    DateTime @default(now())

  announcement SystemAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

// ==================== Admin Audit Log ====================

model AdminAuditLog {
  id            String    @id @default(cuid())
  action        String // e.g. "block_user", "grant_trial", "change_tier"
  targetType    String // e.g. "user", "announcement", "coupon"
  targetId      String?
  details       String?   @db.Text // JSON details
  // Stage 1.7 — adminId הפך nullable + SetNull כדי שניתן יהיה למחוק מזכיר
  adminId       String?
  admin         User?     @relation("auditAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  // Stage 1.7 — snapshot של admin בעת ביצוע (נשמר גם אחרי מחיקת המשתמש)
  adminEmail    String?
  adminName     String?
  // Stage 1.7 — Undo 10 seconds infrastructure
  undoable      Boolean   @default(false)
  undoExpiresAt DateTime?
  revertedAt    DateTime?
  revertedById  String?
  revertedBy    User?     @relation("auditReverted", fields: [revertedById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([undoable, undoExpiresAt]) // לcron ניקוי/validation
}

// ==================== Online Booking ====================

model BookingSettings {
  id                  String      @id @default(cuid())
  enabled             Boolean     @default(false)
  slug                String      @unique
  workingHours        Json        @default("{}")
  breaks              Json        @default("[]")
  sessionDuration     Int         @default(50)
  bufferBetween       Int         @default(10)
  maxAdvanceDays      Int         @default(30)
  minAdvanceHours     Int         @default(24)
  requireApproval     Boolean     @default(true)
  welcomeMessage      String?     @db.Text
  confirmationMessage String?     @db.Text
  defaultSessionType  SessionType @default(IN_PERSON)
  defaultPrice        Decimal?    @db.Decimal(10, 2)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  therapistId         String      @unique
  therapist           User        @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

// ==================== Feature Flags ====================

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "ai_session_prep", "email_threads"
  name        String // display name
  description String?
  isEnabled   Boolean  @default(true) // global on/off
  tiers       String[] @default([]) // allowed tiers: ["ESSENTIAL", "PRO", "ENTERPRISE"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== Support Tickets (פניות ותמיכה) ====================

model SupportTicket {
  id           String            @id @default(cuid())
  ticketNumber Int               @unique // מספר פנייה אוטומטי (5001+)
  userId       String // מי פנה
  user         User              @relation("ticketUser", fields: [userId], references: [id], onDelete: Cascade)
  subject      String // נושא הפנייה
  message      String            @db.Text // תוכן ההודעה (שם שדה קיים — לא משנים)
  attachments  Json? // [{id, filename, contentType, size, fileUrl, uploadedAt}] — צילומי מסך ומסמכים שצורפו
  category     String            @default("general") // general, technical, billing, other
  priority     String            @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status       String            @default("OPEN") // OPEN, IN_PROGRESS, WAITING, RESOLVED, CLOSED
  adminNotes   String?           @db.Text // הערות אדמין (legacy — שדה יחיד, נשאר לתאימות)
  resolvedAt   DateTime?
  resolvedBy   String? // מזהה אדמין שטיפל
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  responses    SupportResponse[]

  // Stage 1.7 — שדות חדשים (additive, נשאר תואם לאחור)
  assignedToId           String?
  assignedToNameSnapshot String?
  assignedTo             User?               @relation("ticketAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  lastReplyAt            DateTime?
  notes                  SupportTicketNote[]

  @@index([userId])
  @@index([status])
  @@index([ticketNumber])
  @@index([status, lastReplyAt]) // לסינון SLA breaches
  @@index([assignedToId, status]) // "פניות שלי" ב-dashboard של מזכיר
}

model SupportResponse {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String // מי כתב (משתמש או אדמין)
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  message     String        @db.Text
  attachments Json? // [{id, filename, contentType, size, fileUrl, uploadedAt}] — צירופים בתגובה
  isAdmin     Boolean       @default(false) // האם זו תגובת אדמין
  createdAt   DateTime      @default(now())

  @@index([ticketId])
}

// Stage 1.7 — הערות פנימיות בין מנהלים (בנוסף ל-SupportResponse הציבורי)
model SupportTicketNote {
  id                 String        @id @default(cuid())
  ticketId           String
  ticket             SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId           String? // nullable — SetNull כשמזכיר נמחק
  author             User?         @relation("noteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  authorNameSnapshot String // snapshot של שם בעת הכתיבה
  content            String        @db.Text
  isInternal         Boolean       @default(true) // ברירת מחדל: הערה פנימית (לא נראית למשתמש)
  createdAt          DateTime      @default(now())

  @@index([ticketId, createdAt])
}

// ==================== Stage 1.7 — Packages (bank system) ====================

enum PackageType {
  SMS
  AI_DETAILED_ANALYSIS
}

enum PackageSource {
  MANUAL // מזכיר/מנהל הוסיף ידנית
  CARDCOM // רכישה אוטומטית דרך סליקה
  PROMO // קידום מכירות / מתנה
}

// קטלוג חבילות לרכישה
model Package {
  id        String                @id @default(cuid())
  type      PackageType
  name      String // "חבילה 100 SMS"
  credits   Int // כמה יחידות כלולות
  priceIls  Decimal               @db.Decimal(10, 2)
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  purchases UserPackagePurchase[]
}

// רכישות של משתמשים — "הבנק"
model UserPackagePurchase {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation("packageUser", fields: [userId], references: [id], onDelete: Cascade)
  packageId     String?
  package       Package?      @relation(fields: [packageId], references: [id], onDelete: SetNull)
  type          PackageType
  credits       Int
  creditsUsed   Int           @default(0)
  grantedBy     String? // userId של המזכיר שהוסיף
  grantedByUser User?         @relation("packageGrantedBy", fields: [grantedBy], references: [id], onDelete: SetNull)
  note          String?       @db.Text
  source        PackageSource
  externalId    String? // מזהה עסקה מקארדקום
  reverted      Boolean       @default(false)
  revertedAt    DateTime?
  revertedBy    String? // userId של מי שביטל
  createdAt     DateTime      @default(now())

  @@index([userId, type])
  @@index([userId, type, reverted])
  @@index([externalId])
}

// ==================== Stage 1.7 — Webhook idempotency ====================

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String // "CARDCOM", "MESHULAM", etc.
  externalId  String // מזהה עסקה של הספק
  rawPayload  Json
  processed   Boolean   @default(false)
  error       String?   @db.Text
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  // Lease-based claim — set when a worker starts processing.
  // If claimedAt is older than the lease window AND processed=false,
  // a retrying worker may take over (recovers from crashed workers).
  claimedAt   DateTime?

  @@unique([provider, externalId])
  @@index([processed, createdAt])
  @@index([claimedAt])
}

// ==================== Stage 1.7 — Request idempotency ====================

model IdempotencyKey {
  key        String   @id // "{adminId}:{clientKey}"
  method     String
  path       String
  statusCode Int
  response   Json
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

// ==================== Cardcom Stage — Site Settings ====================
// Generic key-value store for global ADMIN settings (business type, receipt prefix, etc.)
// Sensitive credentials (API passwords, webhook secrets) belong in env vars, NOT here.

model SiteSetting {
  key         String   @id
  value       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("SiteSettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
}

// ==================== Cardcom Stage — Transactions, Tokens, Invoices ====================

enum CardcomTenant {
  ADMIN // עסקאות מנוי (גלובליות)
  USER // עסקאות מטפל (לכל מטפל credentials משלו)
}

enum CardcomTxStatus {
  PENDING // נוצר דף תשלום, ממתין ל-webhook
  APPROVED // אושר
  DECLINED // נדחה (קוד שגיאה מהבנק)
  FAILED // כשל טכני (network, timeout)
  CANCELLED // המשתמש ביטל
  EXPIRED // דף תשלום פג תוקף
  REFUNDED // הוחזר
}

model CardcomTransaction {
  id String @id @default(cuid())

  // tenancy
  tenant CardcomTenant
  userId String?
  user   User?         @relation("CardcomTxUser", fields: [userId], references: [id], onDelete: SetNull)

  // קישור לאובייקט עסקי
  subscriptionPaymentId String?
  subscriptionPayment   SubscriptionPayment? @relation(fields: [subscriptionPaymentId], references: [id], onDelete: SetNull)
  paymentId             String?
  payment               Payment?             @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  // נתוני Cardcom
  lowProfileId   String? @unique
  // URL של דף התשלום ב-Cardcom (שנשלח ב-/p/pay/[lpId] gateway).
  // שמורים ב-DB כי Cardcom לא נותן API לשחזר אותו לפי LowProfileId.
  paymentPageUrl String?
  transactionId  String?
  approvalNumber String?
  cardLast4      String?
  cardHolder     String?
  cardBrand      String?

  // טוקן
  token            String?
  tokenExpiryMonth Int?
  tokenExpiryYear  Int?

  // כספי
  amount        Decimal @db.Decimal(10, 2)
  currency      String  @default("ILS")
  numOfPayments Int     @default(1)

  // סטטוס
  status       CardcomTxStatus @default(PENDING)
  errorCode    String?
  errorMessage String?         @db.Text
  rawResponse  Json?

  // ניסיונות חוזרים
  attemptNumber       Int     @default(1)
  parentTransactionId String?

  // Refund tracking — supports multiple partial refunds; full refund when refundedAmount === amount
  refundedAmount Decimal @default(0) @db.Decimal(10, 2)

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  cardcomInvoices  CardcomInvoice[]
  chargebackEvents ChargebackEvent[]

  @@index([tenant, userId, status])
  @@index([subscriptionPaymentId])
  @@index([paymentId])
}

model SavedCardToken {
  id String @id @default(cuid())

  tenant CardcomTenant
  userId String?
  user   User?         @relation("SavedCardTokenUser", fields: [userId], references: [id], onDelete: Cascade)

  // אצל מי הטוקן נרשם
  subscriberId String?
  subscriber   User?   @relation("SavedCardTokenSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  token       String
  // SHA-256 דטרמיניסטי של ה-token, לחיפוש ולuniqueness אחרי שה-token יוצפן
  // (AES-GCM לא דטרמיניסטי — לא יכול להיות unique constraint עליו). השדה
  // אופציונלי כרגע: רשומות legacy (לפני השינוי) יש להן null. data migration
  // ימלא אותן בעתיד כדי לאפשר הצפנה מלאה של token.
  tokenHash   String?
  cardLast4   String
  cardHolder  String
  cardBrand   String?
  expiryMonth Int
  expiryYear  Int

  isActive   Boolean   @default(true)
  deletedAt  DateTime?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptionPayments SubscriptionPayment[]

  // unique על tokenHash במקום token — מאפשר הצפנה לא-דטרמיניסטית של token
  // עתידית. Postgres unique לא נכשל על NULL, אז רשומות legacy עם
  // tokenHash=null לא יפרו את ה-constraint.
  @@unique([tenant, tokenHash])
  @@index([tenant, subscriberId, isActive])
  @@index([tenant, clientId, isActive])
}

enum CardcomInvoiceStatus {
  ISSUED
  VOIDED
  REFUNDED
}

// Records of Cardcom-side reversals (chargeback / cancel / refund initiated
// by Cardcom or the cardholder, not by us). Distinct from `payments.refund`
// which is admin-initiated. Used for monthly chargeback reports and to
// build a block-list of clients with repeated chargebacks.
model ChargebackEvent {
  id String @id @default(cuid())

  cardcomTransactionId String
  cardcomTransaction   CardcomTransaction @relation(fields: [cardcomTransactionId], references: [id], onDelete: Cascade)

  tenant    CardcomTenant
  // Original Cardcom Operation field that triggered detection
  // (e.g. "Chargeback", "Reverse", "Cancel"). Free-form for flexibility.
  operation String
  amount    Decimal       @db.Decimal(10, 2)
  currency  String        @default("ILS")

  /// Webhook payload at the moment of detection.
  rawPayload Json
  /// Manual disposition by admin once verified.
  reviewedAt DateTime?
  reviewNote String?   @db.Text
  // Did we issue a follow-up local refund/void to align our books?
  reconciled Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenant, createdAt])
  @@index([reconciled, createdAt])
}

// Documents found in Cardcom that we don't have a local match for.
// invoice-sync cron writes here when it sees a Cardcom document number with no
// CardcomInvoice/CardcomTransaction. AdminAlert is raised so the admin can
// resolve manually (link to a payment / write off / contact Cardcom).
model OrphanCardcomDocument {
  id     String        @id @default(cuid())
  tenant CardcomTenant
  // The therapist whose Cardcom credentials surfaced this orphan (USER tenant only).
  userId String?
  user   User?         @relation("OrphanCardcomUser", fields: [userId], references: [id], onDelete: SetNull)

  cardcomDocumentNumber String   @unique
  cardcomDocumentType   String
  amount                Decimal  @db.Decimal(10, 2)
  currency              String   @default("ILS")
  customerName          String?
  customerEmail         String?
  pdfUrl                String?
  allocationNumber      String?
  occurredAt            DateTime
  rawDocument           Json

  resolved         Boolean   @default(false)
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolutionNote   String?   @db.Text
  // Optional manual link to the local invoice an admin attached this orphan to.
  linkedInvoiceId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resolved, occurredAt])
  @@index([tenant, userId])
  // Used by the per-therapist "open orphans for this user" view.
  @@index([userId, resolved])
}

// אינדקס מקומי של חשבוניות Cardcom — Cardcom מארחים את ה-PDF, אנחנו שומרים metadata + backup
model CardcomInvoice {
  id String @id @default(cuid())

  // === Tenant — denormalized snapshot (avoids relying on cardcomTransaction.tenant
  // when the transaction may be SetNull'd later, and saves a join on listing) ===
  tenant CardcomTenant

  // === פרטים מ-Cardcom (מקור האמת) ===
  cardcomDocumentNumber String  @unique
  cardcomDocumentType   String
  cardcomDocumentId     String?
  pdfUrl                String?
  viewUrl               String?

  // === backup מקומי (חוק 7 שנים) ===
  localPdfPath        String?
  localPdfHash        String?
  backupAttempts      Int       @default(0)
  lastBackupAttemptAt DateTime?
  backupFailedReason  String?   @db.Text

  // === מערך חשבוניות ישראל (חוק 2024) ===
  allocationNumber String?

  // === snapshot של פרטי המנפיק (חוקית — לא משתנים עם מעבר פטור↔מורשה) ===
  // For ADMIN tenant: issuer = MyTipul; for USER tenant: issuer = the therapist.
  issuerUserId       String?
  issuer             User?    @relation("CardcomInvoiceIssuer", fields: [issuerUserId], references: [id], onDelete: SetNull)
  issuerBusinessType String
  issuerBusinessName String
  issuerIdNumber     String
  vatRateSnapshot    Decimal? @db.Decimal(5, 2)
  amountBeforeVat    Decimal? @db.Decimal(10, 2)
  vatAmount          Decimal? @db.Decimal(10, 2)

  // === הקשר עסקי — מי הלקוח של החשבונית ===
  // ADMIN tenant: subscriber = the therapist paying for MyTipul (User row).
  // USER tenant:  subscriber = the therapist (issuer); recipientClientId points
  //               at the actual Client row that received the invoice.
  // Queries:
  //   "all invoices the system issued TO me as a paying user" → subscriberId=me, tenant=ADMIN
  //   "all invoices issued BY me as a therapist"              → issuerUserId=me, tenant=USER
  //   "all invoices issued TO this client of mine"            → recipientClientId=client, tenant=USER
  subscriberId            String
  subscriber              User    @relation("CardcomInvoiceSubscriber", fields: [subscriberId], references: [id], onDelete: Restrict)
  subscriberNameSnapshot  String
  subscriberEmailSnapshot String?

  // For USER tenant: the Client row this invoice was issued to (FK).
  // For ADMIN tenant: null.
  recipientClientId String?
  recipientClient   Client? @relation("CardcomInvoiceRecipient", fields: [recipientClientId], references: [id], onDelete: SetNull)

  subscriptionPaymentId String?
  subscriptionPayment   SubscriptionPayment? @relation(fields: [subscriptionPaymentId], references: [id], onDelete: SetNull)
  paymentId             String?
  payment               Payment?             @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  cardcomTransactionId  String?
  cardcomTransaction    CardcomTransaction?  @relation(fields: [cardcomTransactionId], references: [id], onDelete: SetNull)

  // === סכומים (תצוגה — מקור האמת ב-Cardcom) ===
  amount      Decimal @db.Decimal(10, 2)
  currency    String  @default("ILS")
  description String

  // === סטטוס ===
  status     CardcomInvoiceStatus @default(ISSUED)
  voidedAt   DateTime?
  voidReason String?              @db.Text

  // === Refund linkage ===
  refundInvoiceId String?
  refundInvoice   CardcomInvoice?  @relation("RefundLink", fields: [refundInvoiceId], references: [id], onDelete: SetNull)
  refundOf        CardcomInvoice[] @relation("RefundLink")

  // === Resend tracking (rate-limit, cross-instance safe) ===
  lastResendAt DateTime?
  resendCount  Int       @default(0)

  // === תאריכים ===
  occurredAt DateTime
  issuedAt   DateTime
  syncedAt   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenant, issuedAt])
  @@index([subscriberId, issuedAt])
  @@index([issuerUserId, issuedAt])
  @@index([recipientClientId, issuedAt])
  @@index([status, issuedAt])
  @@index([cardcomDocumentType, issuedAt])
  @@index([allocationNumber])
}

// ==================== Two-Factor Authentication ====================

// קודי אימות 2FA — נשלחים למייל וגם ל-SMS, תוקפם 10 דקות.
// codeHash הוא sha256 — לא שומרים plaintext.
model TwoFactorCode {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String // sha256 hex של הקוד
  channel    String    @default("BOTH") // BOTH | EMAIL | SMS
  expiresAt  DateTime
  attempts   Int       @default(0) // ניסיונות שגויים — חוסם אחרי 5
  verifiedAt DateTime? // null = לא אומת, ערך = אומת בהצלחה
  createdAt  DateTime  @default(now())

  @@index([userId, verifiedAt])
  @@index([expiresAt])
}

// ==================== Clinic Multi-Tenancy ====================
// משתמשים עצמאיים (organizationId=null) אינם נוגעים בטבלאות הללו.

// Organization — קליניקה רב-מטפלים. כל המטפלים, המזכירות, והבעלים שייכים לה.
// המבנה: Organization 1—N User (members דרך User.organizationId).
//        Organization 1—1 User (owner דרך Organization.ownerUserId — נפרד מ-members).
model Organization {
  id               String  @id @default(cuid())
  name             String
  businessIdNumber String?
  businessName     String?
  businessAddress  String?
  businessPhone    String?
  logoUrl          String?

  // הבעלים — User יחיד שמשליט. ownerIsTherapist קובע אם הוא גם מקבל מטופלים.
  ownerUserId      String  @unique
  owner            User    @relation("OrgOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  ownerIsTherapist Boolean @default(false)

  // תוכנית התמחור — משויכת אוטומטית ב-default plan ביצירה.
  pricingPlanId String
  pricingPlan   ClinicPricingPlan @relation(fields: [pricingPlanId], references: [id], onDelete: Restrict)

  aiTier                AITier             @default(ESSENTIAL)
  subscriptionStatus    SubscriptionStatus @default(TRIALING)
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        User[]               @relation("OrgMembers")
  customContract CustomContract?
  smsUsage       OrgSmsUsage[]
  transferLogs   ClientTransferLog[]
  departures     TherapistDeparture[]

  // Inverse relations מהמודלים הקיימים שמכילים organizationId עם @relation
  clients         Client[]
  therapySessions TherapySession[]
  payments        Payment[]

  @@index([ownerUserId])
  @@index([subscriptionStatus, subscriptionEndsAt])
  @@index([pricingPlanId])
}

// תוכנית תמחור לקליניקה — אדמין יוצר ועורך מ-/admin/pricing/clinic-plans.
// כל קליניקה מצביעה לתוכנית אחת. שינוי מחיר בתוכנית משפיע על כל הקליניקות שמצביעות עליה.
// לחוזה מותאם אישית — שימוש ב-CustomContract שגובר על התוכנית.
model ClinicPricingPlan {
  id           String  @id @default(cuid())
  name         String  @unique // "תוכנית קליניקה רגילה"
  internalCode String  @unique // "CLINIC_STANDARD"
  isActive     Boolean @default(true)
  isDefault    Boolean @default(false) // ברירת מחדל ביצירת קליניקה חדשה

  // תמחור בסיס
  baseFeeIls         Decimal @db.Decimal(10, 2)
  includedTherapists Int     @default(1) // כמה מטפלים כלולים במחיר הבסיס
  perTherapistFeeIls Decimal @db.Decimal(10, 2) // לכל מטפל מעבר ל-includedTherapists

  // הנחת נפח — אופציונלי
  volumeDiscountAtCount   Int? // מ-X מטפלים ומעלה
  perTherapistAtVolumeIls Decimal? @db.Decimal(10, 2) // מחיר חלופי בנפח

  // מזכירות
  freeSecretaries    Int      @default(3)
  perSecretaryFeeIls Decimal? @db.Decimal(10, 2) // null = ללא חיוב

  // SMS
  smsQuotaPerMonth Int @default(500)

  // AI — אופציונלי, אם null אז AI נמכר בנפרד
  aiTierIncluded         AITier?
  aiAddonDiscountPercent Int? // הנחה על תוסף AI מעבר ל-aiTierIncluded

  // תקרות
  maxTherapists  Int? // null = ללא הגבלה
  maxSecretaries Int?

  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizations Organization[]
}

// חוזה מותאם אישית — גובר על ClinicPricingPlan עבור Organization יחיד.
// כשקיים חוזה פעיל (status active + endDate בעתיד), המחיר נלקח ממנו.
model CustomContract {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  monthlyEquivPriceIls Decimal @db.Decimal(10, 2) // המחיר החודשי האפקטיבי
  billingCycleMonths   Int     @default(1) // 1 = חודשי, 12 = שנתי
  customSmsQuota       Int? // null = להשתמש ב-pricingPlan.smsQuotaPerMonth
  customAiTier         AITier? // null = להשתמש ב-organization.aiTier

  startDate         DateTime
  endDate           DateTime
  autoRenew         Boolean  @default(false)
  renewalMonths     Int      @default(12)
  annualIncreasePct Decimal? @db.Decimal(5, 2) // למשל 5.00 = 5% עלייה שנתית

  signedDocumentUrl String? // קישור ל-PDF חתום (אופציונלי)
  notes             String?  @db.Text
  createdById       String
  createdBy         User     @relation("ContractCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([endDate, autoRenew])
  @@index([createdById])
}

// מעקב שימוש SMS חודשי לקליניקה — קלוסטר חודשי.
// שונה מ-CommunicationSetting.smsMonthlyUsage שהוא ברמת User בודד.
model OrgSmsUsage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  month          Int // 1-12
  year           Int
  smsCount       Int          @default(0)

  @@unique([organizationId, year, month])
  @@index([organizationId, year, month])
}

// תהליך עזיבת מטפלת מקליניקה — Patient-driven.
// המטפלת לוחצת "אני עוזבת"; כל מטופל מקבל קישור עם token לבחירה.
// cron יומי משלים את התהליך ב-decisionDeadline (ברירת מחדל 14 יום).
model TherapistDeparture {
  id                   String       @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departingTherapistId String
  departingTherapist   User         @relation("DepartingTherapist", fields: [departingTherapistId], references: [id], onDelete: Cascade)

  status           DepartureStatus @default(PENDING)
  decisionDeadline DateTime
  reason           String?         @db.Text

  initiatedAt DateTime  @default(now())
  completedAt DateTime?

  choices ClientDepartureChoice[]

  @@index([organizationId, status])
  @@index([decisionDeadline])
  @@index([departingTherapistId])
}

// בחירת מטופל — האם להישאר בקליניקה או ללכת עם המטפלת.
// decisionToken: cuid ייחודי שנשלח במייל/SMS למטופל; דף ציבורי /p/departure-choice/{token}.
// ברירת מחדל ב-deadline = STAY_WITH_CLINIC (UNDECIDED הופך לכך).
model ClientDepartureChoice {
  id          String             @id @default(cuid())
  departureId String
  departure   TherapistDeparture @relation(fields: [departureId], references: [id], onDelete: Cascade)
  clientId    String
  // Cascade — אם מטופל נמחק, גם רשומת הבחירה שלו נמחקת. אין משמעות לבחירה ללא מטופל.
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  choice        DepartureChoice @default(UNDECIDED)
  decidedAt     DateTime?
  decisionToken String          @unique
  ipAddress     String?

  @@unique([departureId, clientId])
  @@index([decisionToken])
  @@index([clientId])
}

// לוג העברת מטופל בין מטפלים בתוך אותה קליניקה (העברה פנימית).
// שונה מ-TherapistDeparture שהוא יציאה מהקליניקה.
// snapshot של שמות נשמר למקרה שמשתמש נמחק לאחר ההעברה.
model ClientTransferLog {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId        String
  fromTherapistId String
  toTherapistId   String
  performedById   String
  performedBy     User         @relation("TransferPerformer", fields: [performedById], references: [id], onDelete: Restrict)
  reason          String?      @db.Text

  fromTherapistNameSnapshot String
  toTherapistNameSnapshot   String
  performedByNameSnapshot   String

  transferredAt DateTime @default(now())

  @@index([organizationId, transferredAt])
  @@index([clientId, transferredAt])
  @@index([performedById])
}
