// ==================== Admin Audit Log ====================

model AdminAuditLog {
  id            String    @id @default(cuid())
  action        String // e.g. "block_user", "grant_trial", "change_tier"
  targetType    String // e.g. "user", "announcement", "coupon"
  targetId      String?
  details       String?   @db.Text // JSON details
  // Stage 1.7 — adminId הפך nullable + SetNull כדי שניתן יהיה למחוק מזכיר
  adminId       String?
  admin         User?     @relation("auditAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  // Stage 1.7 — snapshot של admin בעת ביצוע (נשמר גם אחרי מחיקת המשתמש)
  adminEmail    String?
  adminName     String?
  // Stage 1.7 — Undo 10 seconds infrastructure
  undoable      Boolean   @default(false)
  undoExpiresAt DateTime?
  revertedAt    DateTime?
  revertedById  String?
  revertedBy    User?     @relation("auditReverted", fields: [revertedById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([undoable, undoExpiresAt]) // לcron ניקוי/validation
  // Stage 2.0 (#13) — compound index לדשבורד "פעולות אדמין לאורך זמן".
  // מאיץ את ה-query הנפוץ "מה X עשה ב-30 הימים האחרונים" — ובמיוחד אחרי
  // שטבלת ה-audit גדלה. createdAt קודם ב-key כדי שגם range scan יעיל.
  @@index([createdAt, adminId])
}

// ==================== Data Access Audit Log (M2) ====================
//
// טבלה מבודלת מ-AdminAuditLog. בעוד AdminAuditLog מתעדת *פעולות ניהול*
// (חסימה, הענקת תוקף, וכו'), הטבלה הזו מתעדת *קריאות לנתונים רגישים*:
// מי קרא תמלול/סיכום פגישה/הקלטה/אבחנה/וכו'. חיוני להתאמה לתקנת
// ההגנה על מידע רפואי-נפשי (תקנות הגנת הפרטיות 2017 + חוק חולה הנפש).
//
// Tamper-proof: אסור UPDATE על השורות לאחר insert. רק cron retention יכול
// למחוק (אחרי 12 חודשים). ADMIN רואה ב-/admin/audit/data-access אבל לא יכול
// למחוק יחידנית — אכיפה ברמת ה-API (אין endpoint למחיקה).

model DataAccessAuditLog {
  id         String   @id @default(cuid())
  // userId nullable + SetNull — במחיקת משתמש, ה-audit log נשאר עם snapshot
  // ב-userEmail/userName. חיוני: לא מאבדים תיעוד היסטורי במחיקת חשבון.
  userId     String?
  user       User?    @relation("dataAuditUser", fields: [userId], references: [id], onDelete: SetNull)
  // snapshot של המשתמש בעת הפעולה — לא מסתמך על JOIN (audit-safe)
  userEmail  String?
  userName   String?
  recordType String // RECORDING | SESSION_NOTE | TRANSCRIPTION | ANALYSIS | CLIENT_NOTES | CLIENT_PROFILE | SESSION_DETAIL | PAYMENT | DOCUMENT
  recordId   String
  action     String // READ | EXPORT | PRINT | DELETE | UPDATE
  clientId   String? // אם הרשומה קשורה ללקוח (לסינון פר-לקוח)
  ipAddress  String?
  userAgent  String?  @db.Text
  meta       String?  @db.Text // JSON metadata
  createdAt  DateTime @default(now())

  // אינדקסים לשליפת audit:
  @@index([userId, createdAt]) // "מה X עשה לאורך זמן"
  @@index([recordType, recordId]) // "מי ניגש ל-X"
  @@index([clientId, createdAt]) // "מי ניגש לנתוני לקוח Y"
  @@index([createdAt]) // לcron retention + dashboards לאורך זמן
  @@index([action, createdAt]) // לדשבורדים לפי סוג פעולה
}

// ==================== Breach Incident Log (R5, סבב 17e) ====================
//
// תקנות הגנת הפרטיות (אבטחת מידע) 2017 §11: חובה לדווח לרשם הגנת הפרטיות
// תוך 72 שעות על "אירוע אבטחה חמור" (פריצה, דליפה, אובדן נתוני PHI).
//
// המודל הזה הוא המקור הרשמי לתיעוד אירועי אבטחה. ADMIN מתעד דרך
// /admin/breach-incidents UI. השדות עוקבים אחר ה-template של רשם הפרטיות.
//
// אסור למחוק רשומות — `severity=CRITICAL` חייבת להישמר לתיעוד היסטורי
// גם אחרי שנים. אכיפה ברמת ה-API (אין DELETE endpoint).

model BreachIncident {
  id                     String         @id @default(cuid())
  // detectedAt — מתי התגלה (יכול להיות אחרי occurredAt)
  detectedAt             DateTime       @default(now())
  // occurredAt — מתי האירוע קרה בפועל (אם ידוע). null = לא ידוע מתי התחיל.
  occurredAt             DateTime?
  severity               BreachSeverity @default(MEDIUM)
  category               BreachCategory
  title                  String         @db.Text
  description            String         @db.Text
  // affectedClientIds — JSON array של clientIds שנפגעו (לתחקור צולב).
  // אם null — לא ידוע / כלל המערכת.
  affectedClientIds      Json?
  affectedClientsCount   Int            @default(0)
  // notifiedRegistrarAt — מתי דווח לרשם הגנת הפרטיות (72-hr clock).
  notifiedRegistrarAt    DateTime?
  // notifiedClientsAt — מתי המטופלים שנפגעו יודעו (אם רלוונטי).
  notifiedClientsAt      DateTime?
  // resolution — מה נעשה כדי לסגור (תיקון, rotation, וכו').
  resolution             String?        @db.Text
  resolvedAt             DateTime?
  status                 BreachStatus   @default(OPEN)
  // reportedById — ADMIN שתיעד את האירוע (לא בהכרח שגילה).
  reportedById           String
  reportedBy             User           @relation("BreachReporter", fields: [reportedById], references: [id], onDelete: Restrict)
  // snapshot של שם המדווח — לתיעוד היסטורי אם המשתמש נמחק.
  reportedByNameSnapshot String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([severity, detectedAt])
  @@index([status, detectedAt])
  @@index([category, detectedAt])
}

enum BreachSeverity {
  LOW // לדוגמה: misconfigured cookie scope, צפייה לא מורשית של רשומה יחידה
  MEDIUM // לדוגמה: דליפת email/phone של מעט מטופלים
  HIGH // לדוגמה: PHI של 10+ מטופלים, או credentials של מטפל
  CRITICAL // לדוגמה: פריצה למסד נתונים, חשיפת ENCRYPTION_KEY, ransomware
}

enum BreachCategory {
  UNAUTHORIZED_ACCESS // משתמש לא מורשה הצליח לראות נתונים
  DATA_LEAK // נתונים זלגו החוצה (בטעות, hack, vendor)
  CREDENTIAL_COMPROMISE // סיסמה/token/key נחשפו
  PHISHING // ניסיון/הצלחה של phishing על משתמש
  SYSTEM_FAILURE // תקלה שגרמה לחשיפה (bug, misconfig)
  PHYSICAL_LOSS // אובדן/גניבת מכשיר עם data
  THIRD_PARTY // ספק חיצוני (Resend, Render, Google) דיווח על אירוע
  OTHER
}

enum BreachStatus {
  OPEN // נפתח, עדיין נחקר
  INVESTIGATING // בחקירה פעילה
  CONTAINED // נעצרה דליפה; ייתכן ועוד תיקונים
  RESOLVED // נסגר לחלוטין + דווח לרשם אם נדרש
  FALSE_ALARM // התברר שלא היה אירוע אמיתי
}

// ==================== Online Booking ====================

model BookingSettings {
  id                  String      @id @default(cuid())
  enabled             Boolean     @default(false)
  slug                String      @unique
  workingHours        Json        @default("{}")
  breaks              Json        @default("[]")
  sessionDuration     Int         @default(50)
  bufferBetween       Int         @default(10)
  maxAdvanceDays      Int         @default(30)
  minAdvanceHours     Int         @default(24)
  requireApproval     Boolean     @default(true)
  welcomeMessage      String?     @db.Text
  confirmationMessage String?     @db.Text
  defaultSessionType  SessionType @default(IN_PERSON)
  defaultPrice        Decimal?    @db.Decimal(10, 2)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  therapistId         String      @unique
  therapist           User        @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

// קישור זימון עצמי אישי לכל מטופל — מחליף את הקישור הכללי (slug) הפתוח לכולם.
// דפוס דומה ל-ClinicInvitation: token חזק (256 ביט), OTP, תוקף, status.
// הפגישה נקשרת ישירות ל-clientId — אין matching לפי שם/מייל ואין יצירת מטופל חדש.
enum BookingLinkStatus {
  ACTIVE // פעיל — ניתן לשימוש
  EXPIRED // פג תוקף (expiresAt עבר)
  REVOKED // בוטל ידנית ע"י המטפל
  BLOCKED // נחסם אוטומטית אחרי יותר מדי כשלי OTP
}

model BookingLink {
  id          String            @id @default(cuid())
  token       String            @unique // 32 bytes base64url = 256 ביט
  clientId    String
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  therapistId String // == client.therapistId בעת היצירה
  // snapshot לscope (בעלים/מזכירה רואים לפי organizationId)
  organizationId String?

  // ערוץ אימות — snapshot בעת היצירה. מתעד למה נשלח הקוד גם אם פרטי המטופל ישתנו.
  destinationEmail String?
  destinationPhone String?

  status    BookingLinkStatus @default(ACTIVE)
  expiresAt DateTime // now + 60 יום

  // OTP per-session — נוצר מחדש בכל בקשת אימות, נמחק אחרי שימוש מוצלח.
  otpHash         String? // bcrypt(10) של 6 ספרות
  otpExpiresAt    DateTime? // תוקף הקוד (10 דק')
  otpAttempts     Int       @default(0) // כשלי אימות מצטברים → BLOCKED ב-OTP_MAX_ATTEMPTS
  otpSendCount    Int       @default(0) // מספר שליחות בחלון 24ש (cap נגד abuse)
  otpSendWindowAt DateTime? // תחילת חלון ה-24ש לספירת השליחות
  lastOtpSentAt   DateTime? // rate-limit 1/דקה על שליחת קוד
  otpVerifiedAt   DateTime? // תחילת חלון מאומת (30 דק' לקביעת תור)

  usageCount Int       @default(0) // כמה תורים נקבעו דרך הקישור
  lastUsedAt DateTime?
  lastSentAt DateTime? // מתי הקישור (חזר ו)נשלח למטופל

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([expiresAt])
}

// ==================== Feature Flags ====================

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "ai_session_prep", "email_threads"
  name        String // display name
  description String?
  isEnabled   Boolean  @default(true) // global on/off
  tiers       String[] @default([]) // allowed tiers: ["ESSENTIAL", "PRO", "ENTERPRISE"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== Support Tickets (פניות ותמיכה) ====================

model SupportTicket {
  id           String            @id @default(cuid())
  ticketNumber Int               @unique // מספר פנייה אוטומטי (5001+)
  userId       String // מי פנה
  user         User              @relation("ticketUser", fields: [userId], references: [id], onDelete: Cascade)
  subject      String // נושא הפנייה
  message      String            @db.Text // תוכן ההודעה (שם שדה קיים — לא משנים)
  attachments  Json? // [{id, filename, contentType, size, fileUrl, uploadedAt}] — צילומי מסך ומסמכים שצורפו
  category     String            @default("general") // general, technical, billing, other
  priority     String            @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status       String            @default("OPEN") // OPEN, IN_PROGRESS, WAITING, RESOLVED, CLOSED
  adminNotes   String?           @db.Text // הערות אדמין (legacy — שדה יחיד, נשאר לתאימות)
  resolvedAt   DateTime?
  resolvedBy   String? // מזהה אדמין שטיפל
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  responses    SupportResponse[]

  // Stage 1.7 — שדות חדשים (additive, נשאר תואם לאחור)
  assignedToId           String?
  assignedToNameSnapshot String?
  assignedTo             User?               @relation("ticketAssigned", fields: [assignedToId], references: [id], onDelete: SetNull)
  lastReplyAt            DateTime?
  notes                  SupportTicketNote[]

  @@index([userId])
  @@index([status])
  @@index([ticketNumber])
  @@index([status, lastReplyAt]) // לסינון SLA breaches
  @@index([assignedToId, status]) // "פניות שלי" ב-dashboard של מזכיר
}

model SupportResponse {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String // מי כתב (משתמש או אדמין)
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  message     String        @db.Text
  attachments Json? // [{id, filename, contentType, size, fileUrl, uploadedAt}] — צירופים בתגובה
  isAdmin     Boolean       @default(false) // האם זו תגובת אדמין
  createdAt   DateTime      @default(now())

  @@index([ticketId])
}

// Stage 1.7 — הערות פנימיות בין מנהלים (בנוסף ל-SupportResponse הציבורי)
model SupportTicketNote {
  id                 String        @id @default(cuid())
  ticketId           String
  ticket             SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId           String? // nullable — SetNull כשמזכיר נמחק
  author             User?         @relation("noteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  authorNameSnapshot String // snapshot של שם בעת הכתיבה
  content            String        @db.Text
  isInternal         Boolean       @default(true) // ברירת מחדל: הערה פנימית (לא נראית למשתמש)
  createdAt          DateTime      @default(now())

  @@index([ticketId, createdAt])
}

// ==================== Stage 1.7 — Packages (bank system) ====================

enum PackageType {
  SMS
  AI_DETAILED_ANALYSIS
}

enum PackageSource {
  MANUAL // מזכיר/מנהל הוסיף ידנית
  CARDCOM // רכישה אוטומטית דרך סליקה
  PROMO // קידום מכירות / מתנה
}

// קטלוג חבילות לרכישה
model Package {
  id        String                @id @default(cuid())
  type      PackageType
  name      String // "חבילה 100 SMS"
  credits   Int // כמה יחידות כלולות
  priceIls  Decimal               @db.Decimal(10, 2)
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  purchases UserPackagePurchase[]
}

// רכישות של משתמשים — "הבנק"
model UserPackagePurchase {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation("packageUser", fields: [userId], references: [id], onDelete: Cascade)
  packageId     String?
  package       Package?      @relation(fields: [packageId], references: [id], onDelete: SetNull)
  type          PackageType
  credits       Int
  creditsUsed   Int           @default(0)
  grantedBy     String? // userId של המזכיר שהוסיף
  grantedByUser User?         @relation("packageGrantedBy", fields: [grantedBy], references: [id], onDelete: SetNull)
  note          String?       @db.Text
  source        PackageSource
  externalId    String? // מזהה עסקה מקארדקום
  reverted      Boolean       @default(false)
  revertedAt    DateTime?
  revertedBy    String? // userId של מי שביטל
  createdAt     DateTime      @default(now())

  // Stage 5 — מניעת race שיוצר 2 UserPackagePurchase לאותה עסקת Cardcom.
  // PostgreSQL מתייחס ל-null כשונה מ-null באינדקסים standard, אז רשומות עם
  // externalId=null (source=ADMIN/PROMO) לא מושפעות; רק (source=CARDCOM,
  // externalId=cuid) נאכף ל-unique.
  @@unique([externalId, source])
  @@index([userId, type])
  @@index([userId, type, reverted])
  @@index([externalId])
}

// ==================== Stage 1.7 — Webhook idempotency ====================

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String // "CARDCOM", "MESHULAM", etc.
  externalId  String // מזהה עסקה של הספק
  rawPayload  Json
  processed   Boolean   @default(false)
  error       String?   @db.Text
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  // Lease-based claim — set when a worker starts processing.
  // If claimedAt is older than the lease window AND processed=false,
  // a retrying worker may take over (recovers from crashed workers).
  claimedAt   DateTime?

  @@unique([provider, externalId])
  @@index([processed, createdAt])
  @@index([claimedAt])
}

// ==================== Stage 1.7 — Request idempotency ====================

model IdempotencyKey {
  key        String   @id // "{adminId}:{clientKey}"
  method     String
  path       String
  statusCode Int
  response   Json
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

// ==================== Cardcom Stage — Site Settings ====================
// Generic key-value store for global ADMIN settings (business type, receipt prefix, etc.)
// Sensitive credentials (API passwords, webhook secrets) belong in env vars, NOT here.

model SiteSetting {
  key         String   @id
  value       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("SiteSettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
}

// ==================== Cardcom Stage — Transactions, Tokens, Invoices ====================

enum CardcomTenant {
  ADMIN // עסקאות מנוי (גלובליות)
  USER // עסקאות מטפל (לכל מטפל credentials משלו)
}

enum CardcomTxStatus {
  PENDING // נוצר דף תשלום, ממתין ל-webhook
  APPROVED // אושר
  DECLINED // נדחה (קוד שגיאה מהבנק)
  FAILED // כשל טכני (network, timeout)
  CANCELLED // המשתמש ביטל
  EXPIRED // דף תשלום פג תוקף
  REFUNDED // הוחזר
}

// מטרת CardcomTransaction — מבדיל בין זרימות שונות שמשתמשות באותו webhook.
// מאפשר ל-webhook לבחור branch נכון בלי לנחש לפי שדות אחרים.
enum CardcomTransactionPurpose {
  SUBSCRIPTION_CREATE // יצירת מנוי חדש / חידוש (זרימה רגילה — subscriptionPaymentId יהיה != null)
  UPDATE_CARD // עדכון כרטיס שמור (CreateTokenOnly, ללא חיוב, subscriptionPaymentId = null)
  PACKAGE_PURCHASE // רכישת חבילת SMS/AI חד-פעמית (שלב 5)
}

model CardcomTransaction {
  id String @id @default(cuid())

  // tenancy
  tenant CardcomTenant
  userId String?
  user   User?         @relation("CardcomTxUser", fields: [userId], references: [id], onDelete: SetNull)

  // קישור לאובייקט עסקי
  subscriptionPaymentId String?
  subscriptionPayment   SubscriptionPayment? @relation(fields: [subscriptionPaymentId], references: [id], onDelete: SetNull)
  paymentId             String?
  payment               Payment?             @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  // מטרת העסקה — מאפשר ל-webhook להבחין בין יצירת מנוי לעדכון כרטיס/רכישת חבילה.
  // null = legacy (רשומות לפני הוספת השדה). webhook מתייחס ל-null כ-SUBSCRIPTION_CREATE
  // לתאימות לאחור.
  purpose CardcomTransactionPurpose?

  // נתוני Cardcom
  lowProfileId   String? @unique
  // URL של דף התשלום ב-Cardcom (שנשלח ב-/p/pay/[lpId] gateway).
  // שמורים ב-DB כי Cardcom לא נותן API לשחזר אותו לפי LowProfileId.
  paymentPageUrl String?
  transactionId  String?
  approvalNumber String?
  cardLast4      String?
  cardHolder     String?
  cardBrand      String?

  // טוקן
  token            String?
  tokenExpiryMonth Int?
  tokenExpiryYear  Int?

  // כספי
  amount        Decimal @db.Decimal(10, 2)
  currency      String  @default("ILS")
  numOfPayments Int     @default(1)

  // סטטוס
  status       CardcomTxStatus @default(PENDING)
  errorCode    String?
  errorMessage String?         @db.Text
  rawResponse  Json?

  // ניסיונות חוזרים
  attemptNumber       Int     @default(1)
  parentTransactionId String?

  // Bulk-payment support — when the transaction was created via the bulk
  // (multi-debt) Cardcom flow, `paymentId` points at an "umbrella" Payment
  // (PENDING, holds the receipt) and `bulkPaymentIds` carries the real
  // child Payment ids to mark PAID after the webhook reports success.
  // Empty for single-payment flows. Stored on the transaction itself so
  // the webhook is self-contained (no extra lookup needed).
  bulkPaymentIds String[] @default([])

  // Refund tracking — supports multiple partial refunds; full refund when refundedAmount === amount
  refundedAmount Decimal @default(0) @db.Decimal(10, 2)

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  cardcomInvoices  CardcomInvoice[]
  chargebackEvents ChargebackEvent[]

  @@index([tenant, userId, status])
  @@index([subscriptionPaymentId])
  @@index([paymentId])
  @@index([status, lowProfileId, createdAt])
}

model SavedCardToken {
  id String @id @default(cuid())

  tenant CardcomTenant
  userId String?
  user   User?         @relation("SavedCardTokenUser", fields: [userId], references: [id], onDelete: Cascade)

  // אצל מי הטוקן נרשם
  subscriberId String?
  subscriber   User?   @relation("SavedCardTokenSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  token       String
  // SHA-256 דטרמיניסטי של ה-token, לחיפוש ולuniqueness אחרי שה-token יוצפן
  // (AES-GCM לא דטרמיניסטי — לא יכול להיות unique constraint עליו). השדה
  // אופציונלי כרגע: רשומות legacy (לפני השינוי) יש להן null. data migration
  // ימלא אותן בעתיד כדי לאפשר הצפנה מלאה של token.
  tokenHash   String?
  cardLast4   String
  cardHolder  String
  cardBrand   String?
  expiryMonth Int
  expiryYear  Int

  isActive   Boolean   @default(true)
  deletedAt  DateTime?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptionPayments SubscriptionPayment[]

  // unique על tokenHash במקום token — מאפשר הצפנה לא-דטרמיניסטית של token
  // עתידית. Postgres unique לא נכשל על NULL, אז רשומות legacy עם
  // tokenHash=null לא יפרו את ה-constraint.
  @@unique([tenant, tokenHash])
  @@index([tenant, subscriberId, isActive])
  @@index([tenant, clientId, isActive])
}

enum CardcomInvoiceStatus {
  ISSUED
  VOIDED
  REFUNDED
}

// Records of Cardcom-side reversals (chargeback / cancel / refund initiated
// by Cardcom or the cardholder, not by us). Distinct from `payments.refund`
// which is admin-initiated. Used for monthly chargeback reports and to
// build a block-list of clients with repeated chargebacks.
model ChargebackEvent {
  id String @id @default(cuid())

  cardcomTransactionId String
  cardcomTransaction   CardcomTransaction @relation(fields: [cardcomTransactionId], references: [id], onDelete: Cascade)

  tenant    CardcomTenant
  // Original Cardcom Operation field that triggered detection
  // (e.g. "Chargeback", "Reverse", "Cancel"). Free-form for flexibility.
  operation String
  amount    Decimal       @db.Decimal(10, 2)
  currency  String        @default("ILS")

  /// Webhook payload at the moment of detection.
  rawPayload Json
  /// Manual disposition by admin once verified.
  reviewedAt DateTime?
  reviewNote String?   @db.Text
  // Did we issue a follow-up local refund/void to align our books?
  reconciled Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenant, createdAt])
  @@index([reconciled, createdAt])
}

// Documents found in Cardcom that we don't have a local match for.
// invoice-sync cron writes here when it sees a Cardcom document number with no
// CardcomInvoice/CardcomTransaction. AdminAlert is raised so the admin can
// resolve manually (link to a payment / write off / contact Cardcom).
model OrphanCardcomDocument {
  id     String        @id @default(cuid())
  tenant CardcomTenant
  // The therapist whose Cardcom credentials surfaced this orphan (USER tenant only).
  userId String?
  user   User?         @relation("OrphanCardcomUser", fields: [userId], references: [id], onDelete: SetNull)

  cardcomDocumentNumber String   @unique
  cardcomDocumentType   String
  amount                Decimal  @db.Decimal(10, 2)
  currency              String   @default("ILS")
  customerName          String?
  customerEmail         String?
  pdfUrl                String?
  allocationNumber      String?
  occurredAt            DateTime
  rawDocument           Json

  resolved         Boolean   @default(false)
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolutionNote   String?   @db.Text
  // Optional manual link to the local invoice an admin attached this orphan to.
  linkedInvoiceId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resolved, occurredAt])
  @@index([tenant, userId])
  // Used by the per-therapist "open orphans for this user" view.
  @@index([userId, resolved])
}

// אינדקס מקומי של חשבוניות Cardcom — Cardcom מארחים את ה-PDF, אנחנו שומרים metadata + backup
model CardcomInvoice {
  id String @id @default(cuid())

  // === Tenant — denormalized snapshot (avoids relying on cardcomTransaction.tenant
  // when the transaction may be SetNull'd later, and saves a join on listing) ===
  tenant CardcomTenant

  // === פרטים מ-Cardcom (מקור האמת) ===
  cardcomDocumentNumber String  @unique
  cardcomDocumentType   String
  cardcomDocumentId     String?
  pdfUrl                String?
  viewUrl               String?

  // === backup מקומי (חוק 7 שנים) ===
  localPdfPath        String?
  localPdfHash        String?
  backupAttempts      Int       @default(0)
  lastBackupAttemptAt DateTime?
  backupFailedReason  String?   @db.Text

  // === מערך חשבוניות ישראל (חוק 2024) ===
  allocationNumber String?

  // === snapshot של פרטי המנפיק (חוקית — לא משתנים עם מעבר פטור↔מורשה) ===
  // For ADMIN tenant: issuer = MyTipul; for USER tenant: issuer = the therapist.
  issuerUserId       String?
  issuer             User?    @relation("CardcomInvoiceIssuer", fields: [issuerUserId], references: [id], onDelete: SetNull)
  issuerBusinessType String
  issuerBusinessName String
  issuerIdNumber     String
  vatRateSnapshot    Decimal? @db.Decimal(5, 2)
  amountBeforeVat    Decimal? @db.Decimal(10, 2)
  vatAmount          Decimal? @db.Decimal(10, 2)

  // === הקשר עסקי — מי הלקוח של החשבונית ===
  // ADMIN tenant: subscriber = the therapist paying for MyTipul (User row).
  // USER tenant:  subscriber = the therapist (issuer); recipientClientId points
  //               at the actual Client row that received the invoice.
  // Queries:
  //   "all invoices the system issued TO me as a paying user" → subscriberId=me, tenant=ADMIN
  //   "all invoices issued BY me as a therapist"              → issuerUserId=me, tenant=USER
  //   "all invoices issued TO this client of mine"            → recipientClientId=client, tenant=USER
  subscriberId            String
  subscriber              User    @relation("CardcomInvoiceSubscriber", fields: [subscriberId], references: [id], onDelete: Restrict)
  subscriberNameSnapshot  String
  subscriberEmailSnapshot String?

  // For USER tenant: the Client row this invoice was issued to (FK).
  // For ADMIN tenant: null.
  recipientClientId String?
  recipientClient   Client? @relation("CardcomInvoiceRecipient", fields: [recipientClientId], references: [id], onDelete: SetNull)

  subscriptionPaymentId String?
  subscriptionPayment   SubscriptionPayment? @relation(fields: [subscriptionPaymentId], references: [id], onDelete: SetNull)
  paymentId             String?
  payment               Payment?             @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  cardcomTransactionId  String?
  cardcomTransaction    CardcomTransaction?  @relation(fields: [cardcomTransactionId], references: [id], onDelete: SetNull)

  // === סכומים (תצוגה — מקור האמת ב-Cardcom) ===
  amount      Decimal @db.Decimal(10, 2)
  currency    String  @default("ILS")
  description String

  // === סטטוס ===
  status     CardcomInvoiceStatus @default(ISSUED)
  voidedAt   DateTime?
  voidReason String?              @db.Text

  // === Refund linkage ===
  refundInvoiceId String?
  refundInvoice   CardcomInvoice?  @relation("RefundLink", fields: [refundInvoiceId], references: [id], onDelete: SetNull)
  refundOf        CardcomInvoice[] @relation("RefundLink")

  // === Resend tracking (rate-limit, cross-instance safe) ===
  lastResendAt DateTime?
  resendCount  Int       @default(0)

  // === תאריכים ===
  occurredAt DateTime
  issuedAt   DateTime
  syncedAt   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenant, issuedAt])
  @@index([subscriberId, issuedAt])
  @@index([issuerUserId, issuedAt])
  @@index([recipientClientId, issuedAt])
  @@index([status, issuedAt])
  @@index([cardcomDocumentType, issuedAt])
  @@index([allocationNumber])
  @@index([paymentId])
}

// ==================== Two-Factor Authentication ====================

// קודי אימות 2FA — נשלחים למייל וגם ל-SMS, תוקפם 10 דקות.
// codeHash הוא sha256 — לא שומרים plaintext.
model TwoFactorCode {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String // sha256 hex של הקוד
  channel    String    @default("BOTH") // BOTH | EMAIL | SMS
  expiresAt  DateTime
  attempts   Int       @default(0) // ניסיונות שגויים — חוסם אחרי 5
  verifiedAt DateTime? // null = לא אומת, ערך = אומת בהצלחה
  createdAt  DateTime  @default(now())

  @@index([userId, verifiedAt])
  @@index([expiresAt])
}

// ==================== Clinic Multi-Tenancy ====================
// משתמשים עצמאיים (organizationId=null) אינם נוגעים בטבלאות הללו.

// Organization — קליניקה רב-מטפלים. כל המטפלים, המזכירות, והבעלים שייכים לה.
// המבנה: Organization 1—N User (members דרך User.organizationId).
//        Organization 1—1 User (owner דרך Organization.ownerUserId — נפרד מ-members).
model Organization {
  id               String  @id @default(cuid())
  name             String
  businessIdNumber String?
  businessName     String?
  businessAddress  String?
  businessPhone    String?
  logoUrl          String?

  // הבעלים — User יחיד שמשליט. ownerIsTherapist קובע אם הוא גם מקבל מטופלים.
  ownerUserId      String  @unique
  owner            User    @relation("OrgOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  ownerIsTherapist Boolean @default(false)

  // תוכנית התמחור — משויכת אוטומטית ב-default plan ביצירה.
  pricingPlanId String
  pricingPlan   ClinicPricingPlan @relation(fields: [pricingPlanId], references: [id], onDelete: Restrict)

  aiTier                AITier             @default(ESSENTIAL)
  subscriptionStatus    SubscriptionStatus @default(TRIALING)
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?

  // M11.G3: אחוז ברירת-מחדל לפיצול הכנסות (0-100). מטפל/ת בקליניקה שאין
  // לו/ה ערך מפורש ב-`User.revenueSharePct` יורש מהשדה הזה. null = ברירת
  // מחדל אחרונה (100% למטפל/ת, כלומר אין פיצול — שומר תאימות לאחור).
  defaultRevenueSharePct Decimal? @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members               User[]                 @relation("OrgMembers")
  customContract        CustomContract?
  smsUsage              OrgSmsUsage[]
  transferLogs          ClientTransferLog[]
  departures            TherapistDeparture[]
  invitations           ClinicInvitation[]
  impersonationSessions ImpersonationSession[]

  // Inverse relations מהמודלים הקיימים שמכילים organizationId עם @relation
  clients         Client[]
  therapySessions TherapySession[]
  payments        Payment[]

  // Pricing — קליניקה יכולה להחזיק policies מותאמות (cascade במחיקה)
  pricingPolicies        PricingPolicy[]        @relation("PricingPolicyForOrg")
  packagePricingPolicies PackagePricingPolicy[] @relation("PackagePricingPolicyForOrg")

  // Team chat — שיחות פנימיות של אנשי הצוות (cascade במחיקת הארגון)
  chatConversations ChatConversation[]

  @@index([ownerUserId])
  @@index([subscriptionStatus, subscriptionEndsAt])
  @@index([pricingPlanId])
}

// תוכנית תמחור לקליניקה — אדמין יוצר ועורך מ-/admin/pricing/clinic-plans.
// כל קליניקה מצביעה לתוכנית אחת. שינוי מחיר בתוכנית משפיע על כל הקליניקות שמצביעות עליה.
// לחוזה מותאם אישית — שימוש ב-CustomContract שגובר על התוכנית.
model ClinicPricingPlan {
  id           String  @id @default(cuid())
  name         String  @unique // "תוכנית קליניקה רגילה"
  internalCode String  @unique // "CLINIC_STANDARD"
  isActive     Boolean @default(true)
  isDefault    Boolean @default(false) // ברירת מחדל ביצירת קליניקה חדשה

  // תמחור בסיס
  baseFeeIls         Decimal @db.Decimal(10, 2)
  includedTherapists Int     @default(1) // כמה מטפלים כלולים במחיר הבסיס
  perTherapistFeeIls Decimal @db.Decimal(10, 2) // לכל מטפל מעבר ל-includedTherapists

  // הנחת נפח — אופציונלי
  volumeDiscountAtCount   Int? // מ-X מטפלים ומעלה
  perTherapistAtVolumeIls Decimal? @db.Decimal(10, 2) // מחיר חלופי בנפח

  // מזכירות
  freeSecretaries    Int      @default(3)
  perSecretaryFeeIls Decimal? @db.Decimal(10, 2) // null = ללא חיוב

  // SMS
  smsQuotaPerMonth Int @default(500)

  // AI — אופציונלי, אם null אז AI נמכר בנפרד
  aiTierIncluded         AITier?
  aiAddonDiscountPercent Int? // הנחה על תוסף AI מעבר ל-aiTierIncluded

  // תקרות
  maxTherapists  Int? // null = ללא הגבלה
  maxSecretaries Int?

  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizations Organization[]
}

// חוזה מותאם אישית — גובר על ClinicPricingPlan עבור Organization יחיד.
// כשקיים חוזה פעיל (status active + endDate בעתיד), המחיר נלקח ממנו.
model CustomContract {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  monthlyEquivPriceIls Decimal @db.Decimal(10, 2) // המחיר החודשי האפקטיבי
  billingCycleMonths   Int     @default(1) // 1 = חודשי, 12 = שנתי
  customSmsQuota       Int? // null = להשתמש ב-pricingPlan.smsQuotaPerMonth
  customAiTier         AITier? // null = להשתמש ב-organization.aiTier
  // תקרות מותאמות (null = להשתמש ב-pricingPlan)
  customMaxTherapists  Int?
  customMaxSecretaries Int?

  startDate         DateTime
  endDate           DateTime
  autoRenew         Boolean  @default(false)
  renewalMonths     Int      @default(12)
  annualIncreasePct Decimal? @db.Decimal(5, 2) // למשל 5.00 = 5% עלייה שנתית

  signedDocumentUrl String? // קישור ל-PDF חתום (אופציונלי)
  notes             String?  @db.Text
  createdById       String
  createdBy         User     @relation("ContractCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([endDate, autoRenew])
  @@index([createdById])
}

// מעקב שימוש SMS חודשי לקליניקה — קלוסטר חודשי.
// שונה מ-CommunicationSetting.smsMonthlyUsage שהוא ברמת User בודד.
model OrgSmsUsage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  month          Int // 1-12
  year           Int
  smsCount       Int          @default(0)

  @@unique([organizationId, year, month])
  @@index([organizationId, year, month])
}

// תהליך עזיבת מטפלת מקליניקה — Patient-driven.
// המטפלת לוחצת "אני עוזבת"; כל מטופל מקבל קישור עם token לבחירה.
// cron יומי משלים את התהליך ב-decisionDeadline (ברירת מחדל 14 יום).
model TherapistDeparture {
  id                   String       @id @default(cuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  departingTherapistId String
  departingTherapist   User         @relation("DepartingTherapist", fields: [departingTherapistId], references: [id], onDelete: Cascade)

  status           DepartureStatus @default(PENDING)
  decisionDeadline DateTime
  reason           String?         @db.Text

  initiatedAt DateTime  @default(now())
  completedAt DateTime?

  choices ClientDepartureChoice[]

  @@index([organizationId, status])
  @@index([decisionDeadline])
  @@index([departingTherapistId])
}

// בחירת מטופל — האם להישאר בקליניקה או ללכת עם המטפלת.
// decisionToken: cuid ייחודי שנשלח במייל/SMS למטופל; דף ציבורי /p/departure-choice/{token}.
// ברירת מחדל ב-deadline = STAY_WITH_CLINIC (UNDECIDED הופך לכך).
model ClientDepartureChoice {
  id          String             @id @default(cuid())
  departureId String
  departure   TherapistDeparture @relation(fields: [departureId], references: [id], onDelete: Cascade)
  clientId    String
  // Cascade — אם מטופל נמחק, גם רשומת הבחירה שלו נמחקת. אין משמעות לבחירה ללא מטופל.
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)

  choice        DepartureChoice @default(UNDECIDED)
  decidedAt     DateTime?
  decisionToken String          @unique
  ipAddress     String?

  @@unique([departureId, clientId])
  @@index([decisionToken])
  @@index([clientId])
}

// לוג העברת מטופל בין מטפלים בתוך אותה קליניקה (העברה פנימית).
// שונה מ-TherapistDeparture שהוא יציאה מהקליניקה.
// snapshot של שמות נשמר למקרה שמשתמש נמחק לאחר ההעברה.
model ClientTransferLog {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId        String
  fromTherapistId String
  toTherapistId   String
  performedById   String
  performedBy     User         @relation("TransferPerformer", fields: [performedById], references: [id], onDelete: Restrict)
  reason          String?      @db.Text

  fromTherapistNameSnapshot String
  toTherapistNameSnapshot   String
  performedByNameSnapshot   String

  transferredAt DateTime @default(now())

  @@index([organizationId, transferredAt])
  @@index([clientId, transferredAt])
  @@index([performedById])
}

// הזמנת חבר/ה חדש/ה לקליניקה — Email-first, עם אימות SMS OTP אופציונלי.
// מחליף את החיפוש הישן של משתמש קיים (שאיפשר להוסיף בלי הסכמת המוזמן).
//
// Flow:
//   1. בעל/ת קליניקה יוצר/ת invitation עם email + (phone? + intendedName?).
//   2. נשלח מייל עם {NEXTAUTH_URL}/invite/{token}; אם יש phone → SMS עם OTP.
//   3. המוזמן/ת לוחץ/ת על הקישור → אם user קיים: re-auth + OTP; אם לא: רישום + OTP.
//   4. accept מאחד את ה-User לארגון, ובהתאם ל-billingPaidByClinic — משעה את המנוי שלו.
//
// טוקן: 32 בייטים רנדומליים ב-base64url = 43 תווים, 256 ביט אנטרופיה
// (חזק יותר מ-cuid). expiresAt = now + 48h.
// OTP: 6 ספרות, hash ב-bcrypt(10). max 5 ניסיונות → REVOKED אוטומטית.
model ClinicInvitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email                String // lowercase, trimmed
  phone                String? // E.164 format (אופציונלי)
  intendedName         String? // רמז למוזמן/ת — לא קובע, רק מציג ב-UI
  clinicRole           ClinicRole // THERAPIST או SECRETARY (לא OWNER)
  // מי משלם על המנוי של המוזמן/ת — שייך ל-MyTipul-B (השעיית מנוי).
  billingPaidByClinic  Boolean    @default(true)
  // הרשאות מזכירה — null אם clinicRole=THERAPIST.
  // Shape זהה ל-User.secretaryPermissions.
  secretaryPermissions Json?

  token            String  @unique // 32 בייטים base64url = 256 ביט
  smsOtpHash       String? // bcrypt(10) של 6 ספרות; null אם phone לא ניתן
  smsOtpAttempts   Int     @default(0)
  // M11.A6: password attempts על משתמש קיים (re-auth) שמקבל הזמנה.
  // ה-token לבדו לא מאפשר accept — נדרשת גם סיסמה. בלי שכבה הזו, token שדלף
  // היה מאפשר brute-force ארוך טווח (IP rate-limit הוא 10/min, distributable).
  // אחרי INVITATION_PASSWORD_MAX_ATTEMPTS כשלים → ההזמנה REVOKED אוטומטית.
  passwordAttempts Int     @default(0)

  status InvitationStatus @default(PENDING)

  // FK relations: מונע references מתים אחרי מחיקת user.
  // createdBy: Restrict — אסור למחוק owner שיש לו הזמנות פעילות. מאלץ ניקוי מסודר.
  // acceptedBy/revokedBy: SetNull — אם user נמחק, audit הזמנה נשמר ללא reference מת.
  createdById      String
  createdBy        User      @relation("ClinicInvitationsCreated", fields: [createdById], references: [id], onDelete: Restrict)
  expiresAt        DateTime // now + 48h
  createdAt        DateTime  @default(now())
  acceptedAt       DateTime?
  acceptedByUserId String? // userId אחרי accept מוצלח
  acceptedBy       User?     @relation("ClinicInvitationsAccepted", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  revokedAt        DateTime?
  revokedById      String?
  revokedBy        User?     @relation("ClinicInvitationsRevoked", fields: [revokedById], references: [id], onDelete: SetNull)
  // משמש את ה-resend cooldown: rate-limit 1/דקה לכל invitation.
  lastResentAt     DateTime?

  @@index([organizationId, status])
  @@index([email, status])
  @@index([expiresAt])
  @@index([createdById])
  @@index([acceptedByUserId])
  @@index([revokedById])
}

// ==================== Impersonation ====================
// בעל/ת קליניקה (OWNER) יכול/ה להיכנס "כעין" מטפל/ת או מזכיר/ה באותה קליניקה
// לצורך ביקורת בלבד. הפעולות המתבצעות תחת impersonation נרשמות ב-AdminAuditLog
// עם metadata שמזהה את ה-OWNER הפועל מאחורי הקלעים (impersonatorId +
// impersonationSessionId), כך ששרשרת האחריות נשמרת.
//
// אילוצים:
// - יכול להיות רק impersonation אחד פעיל ל-OWNER בו-זמנית. ה-DB אוכף את זה
//   באמצעות partial unique index על (impersonatorId) WHERE endedAt IS NULL.
// - 4 שעות מקסימום — אחרי זה auto-stop בקריאה הבאה ל-API (lazy check).
// - ADMIN/OWNER אחר/ים אינם target חוקי.
// - target חייב להיות באותו organization של ה-OWNER.
//
// snapshot של שמות נשמר ל-deletes (Cascade ינקה את הסשן עצמו, אבל ה-AdminAuditLog
// שומר את ה-metadata בנפרד).
model ImpersonationSession {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // מי מתחזה (תמיד OWNER)
  impersonatorId String
  impersonator   User   @relation("Impersonator", fields: [impersonatorId], references: [id], onDelete: Cascade)

  // מי המוצר של ה-impersonation
  targetUserId String
  targetUser   User   @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  reason      String    @db.Text // חובה — סיבה ל-compliance
  startedAt   DateTime  @default(now())
  endedAt     DateTime? // null = פעיל
  endedReason String? // "MANUAL" | "TIMEOUT_4H" | "USER_BLOCKED" | "TARGET_REMOVED" | "TARGET_BLOCKED"

  // snapshot של שמות לעמידות ל-deletes
  impersonatorNameSnapshot String
  targetNameSnapshot       String

  // IP + user-agent לאודיט
  ipAddress String?
  userAgent String? @db.Text
  // PARTIAL UNIQUE INDEX (impersonatorId WHERE endedAt IS NULL) נוצר ב-migration SQL.
  // Prisma לא תומך ב-partial unique index ב-schema, ולכן יוצרים ידנית.

  @@index([organizationId, startedAt])
  @@index([impersonatorId, startedAt])
  @@index([targetUserId, startedAt])
}

// ==================== Pricing Policies — תמחור גמיש ====================
// מקור אמת לתמחור מנויים + חבילות. סדר עדיפות בעת resolve:
//   USER → CLINIC_MEMBER → ORGANIZATION → GLOBAL → fallback ל-src/lib/pricing.ts
// כל policy הוא immutable point-in-time. שינוי = יצירת רשומה חדשה עם validFrom/Until.

enum PricingScope {
  GLOBAL // מחיר ברירת מחדל לכלל המערכת
  ORGANIZATION // מחיר ספציפי לקליניקה
  CLINIC_MEMBER // מחיר ספציפי למטפלת בתוך קליניקה (מתאר User.id, אבל היררכית מתחת ל-Org)
  USER // מחיר ספציפי למשתמש (override יחיד, הגבוה ביותר)
}

model PricingPolicy {
  id             String        @id @default(cuid())
  scope          PricingScope
  organizationId String? // null אם scope=GLOBAL/USER
  organization   Organization? @relation("PricingPolicyForOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String? // null אם scope=GLOBAL/ORGANIZATION; required אם USER/CLINIC_MEMBER
  targetUser     User?         @relation("PricingPolicyForUser", fields: [userId], references: [id], onDelete: Cascade)
  planTier       AITier // ESSENTIAL | PRO | ENTERPRISE
  // מחירים בש"ח כולל מע"מ
  monthlyIls     Decimal       @db.Decimal(10, 2)
  quarterlyIls   Decimal?      @db.Decimal(10, 2)
  halfYearIls    Decimal?      @db.Decimal(10, 2)
  yearlyIls      Decimal?      @db.Decimal(10, 2)
  validFrom      DateTime      @default(now())
  validUntil     DateTime? // null = פעיל ללא הגבלה
  notes          String?       @db.Text
  createdById    String?
  createdBy      User?         @relation("PricingPolicyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([scope, planTier, validFrom, validUntil])
  @@index([organizationId, planTier])
  @@index([userId, planTier])
}

model PackagePricingPolicy {
  id             String        @id @default(cuid())
  scope          PricingScope
  organizationId String?
  organization   Organization? @relation("PackagePricingPolicyForOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  targetUser     User?         @relation("PackagePricingPolicyForUser", fields: [userId], references: [id], onDelete: Cascade)
  packageType    PackageType // SMS | AI_DETAILED_ANALYSIS
  credits        Int // כמה יחידות בחבילה (לדוגמה 100, 500, 1000)
  priceIls       Decimal       @db.Decimal(10, 2)
  validFrom      DateTime      @default(now())
  validUntil     DateTime?
  notes          String?       @db.Text
  createdById    String?
  createdBy      User?         @relation("PackagePricingPolicyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([scope, packageType, credits, validFrom, validUntil])
  @@index([organizationId, packageType])
  @@index([userId, packageType])
}

// ==================== Team Chat (צ'אט צוות פנימי) ====================
// צ'אט פנימי בין בעלת הקליניקה (OWNER) למזכירות (SECRETARY) באותו ארגון.
// בידוד מלא לפי organizationId — אף פעם לא חוצה-קליניקה. שיחות פרטיות (DIRECT)
// וערוץ "כל הצוות" (GROUP). מטפל עצמאי (organizationId=null) — אין לו צ'אט.

enum ChatConversationType {
  DIRECT // שיחה פרטית 1-על-1
  GROUP // קבוצה / ערוץ "כל הצוות"
}

model ChatConversation {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           ChatConversationType
  title          String? // שם הקבוצה; null לשיחה פרטית
  isTeamChannel  Boolean              @default(false) // ערוץ "כל הצוות" הקבוע (אחד לארגון)
  createdById    String
  createdBy      User                 @relation("ChatConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  lastMessageAt  DateTime?
  createdAt      DateTime             @default(now())

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([organizationId, lastMessageAt])
  @@index([organizationId, isTeamChannel])
}

model ChatParticipant {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime? // בסיס לחישוב "לא נקרא" — הודעות אחרי הזמן הזה נחשבות חדשות
  isMuted        Boolean          @default(false)
  joinedAt       DateTime         @default(now())
  leftAt         DateTime? // עזב/ה את השיחה — לא רואה הודעות חדשות

  @@unique([conversationId, userId])
  @@index([userId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User             @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String           @db.Text
  isAnnouncement Boolean          @default(false) // "הודעה חשובה" של המנהלת — מובלטת/נעוצה
  clientId       String? // קישור מטופל אופציונלי (מכובד-הרשאות). SetNull במחיקת מטופל.
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  editedAt       DateTime?
  deletedAt      DateTime? // מחיקה רכה — ההודעה נשמרת ל-audit

  @@index([conversationId, createdAt])
}
