  @@index([userId, status, createdAt])
  @@index([userId, createdAt])
  @@index([type, status, createdAt])
}

enum NotificationType {
  MORNING_SUMMARY
  EVENING_SUMMARY
  PENDING_TASKS
  PAYMENT_REMINDER
  SESSION_REMINDER
  EMAIL_SENT
  EMAIL_RECEIVED
  CANCELLATION_REQUEST
  BOOKING_REQUEST
  CUSTOM
