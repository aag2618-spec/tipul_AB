// Prisma schema for Therapy Practice Management System
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== Authentication ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== Core Models ====================

enum Role {
  USER
  MANAGER // משתמש עם הרשאות ניהול
  ADMIN
  CLINIC_OWNER // בעל/ת קליניקה רב-מטפלים — רואה את כל המטפלים והמזכירות בארגון
  CLINIC_SECRETARY // מזכיר/ה בקליניקה — לפי secretaryPermissions, חסום מתוכן קליני
}

// תפקיד בתוך הקליניקה — relevant only when User.organizationId != null.
enum ClinicRole {
  OWNER
  THERAPIST
  SECRETARY
}

enum DepartureStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum DepartureChoice {
  UNDECIDED
  STAY_WITH_CLINIC
  FOLLOW_THERAPIST
}

// סטטוס הזמנה לקליניקה — שולט ב-flow של ClinicInvitation.
// PENDING → ACCEPTED (מוזמן/ת אישר/ה) | EXPIRED (expiresAt עבר) |
// REVOKED (בעל/ת הקליניקה ביטל/ה) | REJECTED (מוזמן/ת דחה/תה — אופציונלי).
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
  REJECTED
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  // C7: זמן שינוי סיסמה אחרון — משמש להבטלת tokens שהונפקו לפני שינוי הסיסמה.
  // אם token.iat < passwordChangedAt, ה-JWT callback מסמן את ה-token כ-stale
  // ומידלוור/requireAuth דוחים את הבקשה (302 ל-login).
  passwordChangedAt   DateTime?
  // H6 (סבב אבטחה 14, 2026-05-19): session version — מספר שמוגדל ב-2FA
  // enable/disable, password change, admin block. JWT שמור עם `token.sv`
  // שווה לערך בעת login. ב-jwt callback משווים מול `user.sessionVersion`
  // הנוכחי — אם שונה, המשתמש ביצע פעולה רגישה אחרי הנפקת ה-token וה-token
  // נפסל (`sessionStale`). מונע שימוש ב-cookies גנובות אחרי שינוי credentials.
  // legacy tokens (ללא `token.sv`) פטורים עד login הבא — תאימות אחורית.
  sessionVersion      Int       @default(0)
  // H11: account lockout. failedLoginAttempts מתאפס על login מוצלח או כאשר
  // lockedUntil עבר. lockedUntil > now() חוסם — גם אם הסיסמה נכונה.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  phone               String?
  license             String?
  role                Role      @default(USER)
  isBlocked           Boolean   @default(false)
  // סיבת חסימה — null אם isBlocked=false. ערכים: DEBT | TOS_VIOLATION | MANUAL.
  // משמש את ה-webhooks לאוטו-שחרור: רק DEBT משתחרר אוטומטית בתשלום מוצלח;
  // TOS_VIOLATION ו-MANUAL נשארים חסומים עד החלטה ידנית של אדמין.
  blockReason         String?
  blockedAt           DateTime?
  blockedBy           String? // userId של האדמין שחסם; null אם נחסם אוטומטית (cron / system)

  // Two-Factor Authentication (2FA) — נאכף בקוד רק לאנשי צוות (USER/MANAGER/ADMIN)
  twoFactorEnabled       Boolean   @default(true)
  // H4: שיטת 2FA. "OTP" = קוד שנשלח במייל/SMS (legacy). "TOTP" = Google
  // Authenticator (RFC 6238) — חזק יותר, מתנגד SIM-swap.
  // null = ברירת מחדל OTP (תאימות אחורית עד שהמשתמש משדרג).
  twoFactorMethod        String? // "OTP" | "TOTP" | null
  // H4: TOTP secret (base32). מוצפן ב-DB דרך ENCRYPTED_FIELDS.user.twoFactorSecret
  // (ב-src/lib/encrypted-fields.ts). null עד שהמשתמש מסיים flow הגדרת TOTP.
  twoFactorSecret        String?   @db.Text
  // H18: Recovery codes — JSON של מערך bcrypt hashes (10 קודים חד-פעמיים).
  // נוצרים בעת הפעלת TOTP; כל קוד שמנוצל מוסר מהמערך.
  // null עד הפעלת TOTP. ריק (מערך עם [] שווה ערך ל-null) = המשתמש ניצל את כולם.
  twoFactorRecoveryCodes String?   @db.Text
  lastLoginAt            DateTime?
  lastActivityAt         DateTime? // מתי הייתה הפעולה האחרונה — בסיס לחישוב 3 שעות חוסר פעילות
  defaultSessionDuration Int       @default(50) // משך פגישה סטנדרטית בדקות
  defaultSessionPrice    Decimal?  @db.Decimal(10, 2) // מחיר ברירת מחדל לפגישה

  // M11.G3: אחוז ההכנסה שמטפל/ת מקבל/ת מפגישות שלו/ה בקליניקה רב-מטפלים.
  // 0-100. null = יורש מ-Organization.defaultRevenueSharePct (ובהיעדרו — 100%
  // למטפל/ת, כלומר אין פיצול). הערך לא משפיע על UI/חישוב למתפלים עצמאיים
  // (organizationId=null) ועל זרימת Payment הקיימת — כרגע משמש רק לדוח
  // /clinic-admin/revenue. שילוב ב-Payment flow יתבצע בקומיט נפרד (B).
  revenueSharePct Decimal? @db.Decimal(5, 2)

  // AI & Billing Settings
  aiTier                AITier   @default(ESSENTIAL) // Essential, Pro, Enterprise
  therapeuticApproaches String[] @default([]) // Array of approaches: ["CBT", "Psychodynamic", etc.]
  approachDescription   String?  @db.Text // Custom description for eclectic approach
  analysisStyle         String   @default("professional") // professional, practical, emotional
  aiTone                String   @default("formal") // formal, warm, direct
  customAIInstructions  String?  @db.Text // Custom instructions for AI

  // Billing
  stripeCustomerId      String?            @unique // Stripe customer ID
  stripeSubscriptionId  String?            @unique // Stripe subscription ID
  // Anti-IDOR: מזהה customer ב-Meshulam. נקבע ב-webhook subscription הראשון,
  // ובכל webhook הבא נאמת שתואם. מונע תוקף שמזייף customerEmail של משתמש אחר.
  meshulamCustomerId    String?            @unique
  subscriptionStatus    SubscriptionStatus @default(ACTIVE)
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  trialEndsAt           DateTime?

  // Email verification
  emailVerificationToken   String? // טוקן אימות מייל
  emailVerificationExpires DateTime? // תפוגת טוקן אימות

  // Trial AI usage limit
  trialAiCostLimit Decimal @default(5) @db.Decimal(10, 2) // תקרת עלות AI בניסיון (₪)
  trialAiUsedCost  Decimal @default(0) @db.Decimal(10, 4) // עלות AI שנוצלה בניסיון

  // Free Subscription (מנוי חינם - ניתן ע"י מנהל)
  isFreeSubscription        Boolean   @default(false)
  freeSubscriptionNote      String? // הערה למה ניתן חינם
  freeSubscriptionGrantedAt DateTime? // מתי ניתן

  // Clinic billing pause (MyTipul B) — כש-billingPaidByClinic=true, המנוי האישי
  // מושעה ל-PAUSED. בעזיבה/הסרה מהקליניקה, חוזרים ל-subscriptionStatusBeforeClinic
  // (או TRIALING חדש אם זה היה null).
  billingPaidByClinic            Boolean             @default(false)
  subscriptionPausedReason       String? // "PAID_BY_CLINIC" כעת; ערכים נוספים בעתיד.
  subscriptionPausedAt           DateTime?
  subscriptionStatusBeforeClinic SubscriptionStatus? // לשחזור בעזיבה.
  // M11.E1: aiTier ערב הצטרפות לקליניקה — לשחזור בעזיבה. null = "לא נשמר"
  // (לרוב כי המשתמש לא ירש tier ארגוני; aiTier הנוכחי שלו נשאר על כנו).
  aiTierBeforeClinic             AITier? // לשחזור aiTier אם הירש tier ארגוני

  // שדרוג tier בתוך תקופה פעילה: שילם עבור תקופה עתידית, ה-tier יחול רק
  // אחרי שהתקופה הקודמת מסתיימת. cron יומי מקדם pendingTier→aiTier כש-now >= pendingTierEffectiveAt.
  pendingTier            AITier?
  pendingTierEffectiveAt DateTime?

  // Usage limits
  maxActiveClients Int  @default(40) // Maximum active clients allowed
  userNumber       Int? @unique // מספר משתמש ייחודי (1001+)

  // ==================== Clinic Multi-Tenancy ====================
  // null = מטפל עצמאי (התנהגות קיימת, ללא שינוי).
  // ערך = שייך לארגון/קליניקה רב-מטפלים. clinicRole חייב להיות מוגדר.
  organizationId       String?
  organization         Organization? @relation("OrgMembers", fields: [organizationId], references: [id], onDelete: SetNull)
  clinicRole           ClinicRole? // OWNER/THERAPIST/SECRETARY — null אם organizationId=null.
  // מטריצת הרשאות מזכירה — רלוונטי רק ל-clinicRole=SECRETARY.
  // Shape: { canViewPayments, canIssueReceipts, canSendReminders, canCreateClient, canViewDebts, canViewStats }
  // NOTE: גישה לתוכן קליני (סיכומים/אבחנות/AI/הקלטות) חסומה קשיחות בקוד — לא ניתנת לעריכה דרך השדה הזה.
  secretaryPermissions Json?

  // Business & Receipt Settings (הגדרות עסק וקבלות)
  businessType       BusinessType     @default(NONE) // סוג עסק
  businessName       String? // שם העסק
  businessIdNumber   String? // ת.ז./ח.פ./מספר עוסק — חובה חוקית לחשבונית מס (LICENSED)
  businessPhone      String? // טלפון עסקי
  businessAddress    String? // כתובת העסק
  // שיטת חשבונאות (CASH = מקבל-תשלום: חשבונית מוצאת בעת תשלום;
  // ACCRUAL = מצטבר: חשבונית מס בעת הסכם, קבלה בעת תשלום — שני מסמכים).
  // עוסק מורשה במחזור 50K+ עובר אוטומטית למצטבר. שדה זה משפיע על document type
  // שנשלח ל-Cardcom (ב-CASH=TaxInvoiceAndReceipt; ב-ACCRUAL נדרשת זרימה דו-שלבית).
  accountingMethod   AccountingMethod @default(CASH)
  nextReceiptNumber  Int              @default(1) // מספר הקבלה הבא
  receiptDefaultMode ReceiptMode      @default(ASK) // ברירת מחדל לקבלות

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts               Account[]
  sessions               Session[]
  clients                Client[]
  therapySessions        TherapySession[]
  documents              Document[]
  notifications          Notification[]
  tasks                  Task[]
  notificationSettings   NotificationSetting[]
  recurringPatterns      RecurringPattern[]
  intakeTemplates        IntakeTemplate[]
  apiUsageLogs           ApiUsageLog[]
  subscriptionPayments   SubscriptionPayment[]
  reviewedCancellations  CancellationRequest[]
  communicationLogs      CommunicationLog[]
  communicationSetting   CommunicationSetting?
  couponUsages           CouponUsage[]
  questionnaireResponses QuestionnaireResponse[]
  intakeQuestionnaires   IntakeQuestionnaire[]   @relation("intakeQuestionnaires")
  passwordResets         PasswordReset[]
  smsSettings            SMSSettings?
  consentForms           ConsentForm[]
  insurerSettings        InsurerSettings?
  insurerReports         InsurerReport[]
  clientCommitments      ClientCommitment[]
  billingProviders       BillingProvider[]
  aiUsageStats           AIUsageStats?
  sessionPreps           SessionPrep[]

  // Online Booking
  bookingSettings BookingSettings?

  // AI Insights Relations
  aiInsights       AIInsight[]
  therapeuticGoals TherapeuticGoal[]
  emotionLogs      EmotionLog[]
  termsAcceptances TermsAcceptance[]

  // AI Analysis Relations
  questionnaireAnalyses QuestionnaireAnalysis[]
  sessionAnalyses       SessionAnalysis[]
  monthlyUsages         MonthlyUsage[]
  adminAuditLogs        AdminAuditLog[]         @relation("auditAdmin")

  // Support Tickets (פניות ותמיכה)
  supportTickets         SupportTicket[]     @relation("ticketUser")
  supportResponses       SupportResponse[]
  supportTicketsAssigned SupportTicket[]     @relation("ticketAssigned")
  supportNotesAuthored   SupportTicketNote[] @relation("noteAuthor")

  // Admin — undo/redo of audit actions (Stage 1.7)
  adminAuditLogsReverted AdminAuditLog[] @relation("auditReverted")

  // Packages — bank purchases granted manually by admin
  packagesGranted  UserPackagePurchase[] @relation("packageGrantedBy")
  packagePurchases UserPackagePurchase[] @relation("packageUser")

  // Site Settings — admin who last updated a global setting
  siteSettingsUpdated SiteSetting[] @relation("SiteSettingUpdater")

  // Cardcom relations
  cardcomTransactions         CardcomTransaction[]    @relation("CardcomTxUser")
  savedCardTokens             SavedCardToken[]        @relation("SavedCardTokenUser")
  subscriberTokens            SavedCardToken[]        @relation("SavedCardTokenSubscriber")
  cardcomInvoicesAsSubscriber CardcomInvoice[]        @relation("CardcomInvoiceSubscriber")
  cardcomInvoicesAsIssuer     CardcomInvoice[]        @relation("CardcomInvoiceIssuer")
  orphanCardcomDocuments      OrphanCardcomDocument[] @relation("OrphanCardcomUser")

  // 2FA codes
  twoFactorCodes TwoFactorCode[]

  // ==================== Clinic relations (inverse) ====================
  ownedOrganization        Organization?        @relation("OrgOwner")
  customContractsCreated   CustomContract[]     @relation("ContractCreator")
  clientTransfersPerformed ClientTransferLog[]  @relation("TransferPerformer")
  departureInitiated       TherapistDeparture[] @relation("DepartingTherapist")
  // R5 (סבב 17e, 2026-05-20): אירועי אבטחה שאדמין דיווח עליהם.
  breachIncidentsReported  BreachIncident[]     @relation("BreachReporter")

  // Clinic invitations — inverse relations.
  // createdBy: Restrict — אסור למחוק owner עם הזמנות פעילות (forensics).
  // acceptedBy/revokedBy: SetNull — מחיקת user שומרת את audit trail של ההזמנה.
  clinicInvitationsCreated  ClinicInvitation[] @relation("ClinicInvitationsCreated")
  clinicInvitationsAccepted ClinicInvitation[] @relation("ClinicInvitationsAccepted")
  clinicInvitationsRevoked  ClinicInvitation[] @relation("ClinicInvitationsRevoked")

  // Impersonation — inverse relations.
  // OWNER מבצע impersonation על THERAPIST/SECRETARY של אותה קליניקה לצורך
  // ביקורת בלבד. שני הצדדים נשמרים ב-Cascade: מחיקת user מנקה גם את
  // הסשנים שלו (audit נשאר ב-AdminAuditLog שמכיל snapshot).
  impersonationsPerformed ImpersonationSession[] @relation("Impersonator")
  impersonatedAs          ImpersonationSession[] @relation("ImpersonationTarget")

  // Pricing policies — inverse relations.
  // SetNull: מחיקת admin שיצר policy שומרת את ההיסטוריה (audit-safe).
  pricingPoliciesCreated            PricingPolicy[]        @relation("PricingPolicyCreator")
  packagePricingPoliciesCreated     PackagePricingPolicy[] @relation("PackagePricingPolicyCreator")
  // Pricing policies — policies שמטרגטות את המשתמש (Cascade במחיקת המשתמש).
  pricingPoliciesTargetingMe        PricingPolicy[]        @relation("PricingPolicyForUser")
  packagePricingPoliciesTargetingMe PackagePricingPolicy[] @relation("PackagePricingPolicyForUser")

  // M2 — Data access audit log (קריאות לנתונים רגישים).
  // SetNull: שמירת היסטוריית audit גם אחרי מחיקת המשתמש (snapshot של email/name נשמר).
  dataAccessAudits DataAccessAuditLog[] @relation("dataAuditUser")

  // ==================== Team Chat (צ'אט צוות פנימי) ====================
  // צ'אט בין בעלת הקליניקה למזכירות. Cascade: מחיקת משתמש מנקה את השיחות
  // שיצר, את ההשתתפויות שלו, ואת ההודעות ששלח.
  chatConversationsCreated ChatConversation[] @relation("ChatConversationCreator")
  chatParticipations       ChatParticipant[]
  chatMessagesSent         ChatMessage[]      @relation("ChatMessageSender")
}

// ==================== AI Tiers ====================

enum AITier {
  ESSENTIAL // 117₪ - ללא AI
  PRO // 145₪ - Gemini 2.0 Flash (תמציתי) - מוצג כ"מקצועי" בממשק
  ENTERPRISE // 220₪ - Gemini 2.0 Flash (מפורט עם גישות) - מוצג כ"ארגוני" בממשק
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  PAUSED
}

// ==================== Admin Alerts System ====================

model AdminAlert {
  id       String         @id @default(cuid())
  type     AdminAlertType
  priority AlertPriority  @default(MEDIUM)
  status   AlertStatus    @default(PENDING)

  // Alert details
  title   String
  message String @db.Text

  // Related entities (optional)
  userId String?

  // Action tracking
  actionRequired String? // מה צריך לעשות
  actionTaken    String?   @db.Text // מה נעשה
  resolvedAt     DateTime?
  resolvedBy     String? // Admin ID who resolved

  // Scheduling for reminders
  scheduledFor DateTime? // מתי להציג/לשלוח
  emailSent    Boolean   @default(false)
  emailSentAt  DateTime?

  // Metadata
  metadata Json? // Additional data (payment IDs, amounts, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([userId])
  @@index([scheduledFor])
  @@index([priority, status])
  @@index([type, userId, status])
}

enum AdminAlertType {
  PAYMENT_DUE // תשלום קרב
  PAYMENT_OVERDUE // תשלום באיחור
  PAYMENT_FAILED // תשלום נכשל
  SUBSCRIPTION_EXPIRING // מנוי עומד לפוג
  SUBSCRIPTION_EXPIRED // מנוי פג
  HIGH_AI_USAGE // שימוש גבוה ב-AI
  NEW_USER // משתמש חדש נרשם
  USER_BLOCKED // משתמש נחסם
  TIER_CHANGE_REQUEST // בקשה לשינוי תוכנית
  MANUAL_REMINDER // תזכורת ידנית
  SYSTEM // התראת מערכת
  SUPPORT_TICKET // פנייה לתמיכה
  // Stage 1.7 — alerts חדשים ל-observability
  CREDIT_CONSUMPTION_FAILED // consumeSms/AI — QUOTA_EXHAUSTED או retry exhausted
  IDEMPOTENCY_REPLAY_OF_FAILURE // בקשה חוזרת עם idempotency-key של שגיאת 5xx
  SERIALIZATION_RETRY_EXHAUSTED // retry על 40001/40P01 נגמר בלי הצלחה
}

enum AlertPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AlertStatus {
  PENDING // טרם טופל
  IN_PROGRESS // בטיפול
  RESOLVED // טופל
  DISMISSED // נדחה
  SNOOZED // נדחה לזמן מאוחר
}

// ==================== Password Reset ====================

model PasswordReset {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Client {
  id                  String       @id @default(cuid())
  firstName           String?
  lastName            String?
  name                String
  phone               String?
  email               String?
  birthDate           DateTime?
  address             String?
  status              ClientStatus @default(ACTIVE)
  isQuickClient       Boolean      @default(false) // פונה מזדמן — נוצר מהיומן עם מינימום פרטים
  defaultSessionPrice Decimal?     @db.Decimal(10, 2)
  creditBalance       Decimal      @default(0) @db.Decimal(10, 2) // יתרת קרדיט
  medicalHistory      Json?
  notes               String?      @db.Text
  initialDiagnosis    String?      @db.Text
  intakeNotes         String?      @db.Text

  // AI Settings - client-specific therapeutic approaches (override therapist defaults)
  therapeuticApproaches String[] @default([]) // Override therapist's default approaches
  approachNotes         String?  @db.Text // Special notes about therapeutic approach for this client
  culturalContext       String?  @db.Text // Cultural context for AI analysis sensitivity

  // Comprehensive AI analysis (saved from "all summaries" page)
  comprehensiveAnalysis   String?   @db.Text
  comprehensiveAnalysisAt DateTime?

  // M1 (2026-05-17): הסכמת מטופל לעיבוד נתוניו בכלי AI חיצוניים (Gemini).
  // ברירת מחדל true — לא רוצים לשבור AI למטופלים קיימים. UI בעתיד יאפשר
  // למטפל לסמן false למטופל שמסרב במפורש. השדה נבדק ב-requireAiConsent
  // — אם false יוחזר 403; null/true עוברים.
  consentToAI   Boolean?  @default(true)
  consentToAIAt DateTime?

  healthFund HealthInsurer?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  therapistId String
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  // Clinic multi-tenancy — null = מטופל של מטפל עצמאי (התנהגות קיימת).
  // ערך = משתייך לקליניקה (חייב להיות זהה ל-organizationId של המטפל).
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  therapySessions        TherapySession[]
  payments               Payment[]
  documents              Document[]
  recordings             Recording[]
  recurringPatterns      RecurringPattern[]
  cancellationRequests   CancellationRequest[]
  communicationLogs      CommunicationLog[]
  questionnaireResponses QuestionnaireResponse[]
  intakeResponses        IntakeResponse[]        @relation("intakeResponses")
  consentForms           ConsentForm[]

  // AI Analysis Relations
  questionnaireAnalyses QuestionnaireAnalysis[]

  // AI Insights Relations
  aiInsights       AIInsight[]
  therapeuticGoals TherapeuticGoal[]
  emotionLogs      EmotionLog[]

  // Cardcom — saved tokens for recurring billing
  savedCardTokens SavedCardToken[]

  // Cardcom — invoices issued TO this client (USER tenant)
  cardcomInvoicesReceived CardcomInvoice[] @relation("CardcomInvoiceRecipient")

  // Clinic departure flow — בחירות שמטופל זה עשה כשמטפלת עוזבת
  departureChoices ClientDepartureChoice[]

  commitments ClientCommitment[]

  // Team chat — הודעות צוות שמקשרות למטופל זה (SetNull במחיקת מטופל)
  chatMessages ChatMessage[]

  // קישורי זימון עצמי אישיים — token לכל מטופל (במקום קישור כללי). Cascade במחיקת מטופל.
  bookingLinks BookingLink[]

  @@index([organizationId])
  @@index([organizationId, therapistId])
  @@index([therapistId])
  @@index([therapistId, status, isQuickClient])
  @@index([organizationId, status, isQuickClient])
  @@index([organizationId, updatedAt(sort: Desc)])
}

enum ClientStatus {
  ACTIVE
  WAITING
  INACTIVE
  ARCHIVED
}

model TherapySession {
  id          String        @id @default(cuid())
  startTime   DateTime
  endTime     DateTime
  status      SessionStatus @default(SCHEDULED)
  type        SessionType   @default(IN_PERSON)
  price       Decimal       @db.Decimal(10, 2)
  topic       String?       @db.Text // נושא הפגישה (חובה לפגישת ייעוץ)
  notes       String?       @db.Text
  location    String?
  isRecurring Boolean       @default(false)
  skipSummary Boolean       @default(false) // האם להסתיר מרשימת "ללא סיכום"

  // Cancellation fields
  cancellationReason      String?   @db.Text
  cancellationRequestedAt DateTime?
  cancelledAt             DateTime?
  cancelledBy             String? // 'CLIENT', 'THERAPIST', 'SYSTEM'

  // M11.G3 (קומיט B): snapshot ש"ח של חלק המטפל/ת מההכנסה של הפגישה, מחושב
  // בעת ש-Payment המקושר עובר למצב PAID. הערך כולל את כל ה-PAID children
  // אם קיימים (תשלום מפוצל). null = לא בוצע snapshot עדיין (פגישה שעדיין
  // לא שולמה במלואה, או פגישה ישנה מלפני פריסת הפיצ'ר, או מטפל/ת עצמאי/ת
  // ללא organizationId). דוח /clinic-admin/revenue ממשיך לחשב live מההגדרות
  // הנוכחיות; השדה הזה משמש לעקיבות חשבונאית עתידית.
  therapistRevenueIls Decimal? @db.Decimal(10, 2)

  // Google Calendar sync
  googleEventId String?

  // Shabbat outbox — מסומן true אם הפגישה נוצרה בשבת/חג ושליחת ההודעות נדחתה
  pendingConfirmationEmail    Boolean @default(false) // מייל אישור ללקוח
  pendingConfirmationSms      Boolean @default(false) // SMS אישור ללקוח
  pendingTherapistNotifyEmail Boolean @default(false) // מייל התראה למטפל

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  therapistId String
  therapist   User   @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  sessionNote          SessionNote?
  payment              Payment?
  recordings           Recording[]
  cancellationRequests CancellationRequest[]
  communicationLogs    CommunicationLog[]
  smsReminders         SMSReminder[]
  insurerReports       InsurerReport[]

  // AI Analysis
  sessionAnalysis SessionAnalysis?
  emotionLogs     EmotionLog[]

  // Clinic multi-tenancy
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, startTime])
  @@index([therapistId, startTime])
  @@index([therapistId, status, startTime])
  @@index([clientId, startTime(sort: Desc)])
  @@index([organizationId, status, startTime])
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  PENDING_CANCELLATION
  PENDING_APPROVAL
  NO_SHOW
}

enum SessionType {
  IN_PERSON
  ONLINE
  PHONE
  BREAK
}

model SessionNote {
  id         String   @id @default(cuid())
  content    String   @db.Text
  isPrivate  Boolean  @default(false)
  aiAnalysis Json? // Stores AI analysis of the note
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessionId String         @unique
  session   TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
