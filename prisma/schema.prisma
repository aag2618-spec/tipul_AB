// ==================== Admin: Subscription Payments ====================

model SubscriptionPayment {
  id          String                    @id @default(cuid())
  amount      Decimal                   @db.Decimal(10, 2)
  currency    String                    @default("ILS")
  status      SubscriptionPaymentStatus @default(PENDING)
  description String?
  invoiceUrl  String?
  periodStart DateTime?
  periodEnd   DateTime?
  paidAt      DateTime?
  // Stage 1.7 — שיטת תשלום (ידני: מזומן/העברה/צ'ק, אוטומטי: אשראי דרך קארדקום)
  method      PaymentMethod?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Cardcom — auto-charge fields (V2: cron) + relations
  autoChargeEnabled   Boolean              @default(false)
  savedCardTokenId    String?
  savedCardToken      SavedCardToken?      @relation(fields: [savedCardTokenId], references: [id], onDelete: SetNull)
  nextChargeAt        DateTime?
  // Dunning — מעקב ניסיונות חיוב חוזרים (3 ניסיונות: יום 1, 3, 7)
  chargeAttempts      Int                  @default(0)
  lastChargeError     String?              @db.Text
  lastAttemptAt       DateTime?
  // firstAttemptAt — מתי הניסיון הראשון של הסבב הנוכחי קרה.
  // משמש לחישוב לוח retry [1, 3, 7] relative-to-first, לא relative-to-now,
  // כך שעיכוב בין ניסיונות לא יסיט את הלוח (1, 3, 9 במקום 1, 3, 7).
  // מתאפס ל-null בהצלחה. נקבע ב-attempt 1 אם null.
  firstAttemptAt      DateTime?
  // dunningSentAttempt — איזה ניסיון dunning email נשלח כבר. מונע
  // duplicate email אם cron נופל בין email-send ל-DB-update ומקלידים שוב.
  dunningSentAttempt  Int                  @default(0)
  // ה-tier שהמשתמש בחר בעת יצירת המנוי. נשמר כאן כדי שה-webhook
  // יוכל להפעיל את ה-tier הנכון רק אחרי APPROVED (לא לפני התשלום).
  planTier            AITier?
  cardcomTransactions CardcomTransaction[]
  cardcomInvoices     CardcomInvoice[]

  @@index([autoChargeEnabled, nextChargeAt])
  @@index([status, nextChargeAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
}

enum SubscriptionPaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

// ==================== Terms Acceptance Log ====================
// רשומות הוכחה חוקיות - לעולם לא למחוק!

model TermsAcceptance {
  id String @id @default(cuid())

  // מי אישר
  userId    String
  user      User    @relation(fields: [userId], references: [id]) // NO cascade - שומר הוכחה גם אם המשתמש נמחק
  userEmail String // מייל בזמן האישור (backup אם המשתמש ישנה מייל)
  userName  String? // שם בזמן האישור

  // מה אושר
  termsVersion    String @default("1.0") // גרסת התנאים שאושרו
  termsType       String // SUBSCRIPTION_TERMS | PRIVACY_POLICY | CANCELLATION_POLICY
  acceptedContent String @db.Text // תקציר התנאים שאושרו

  // הקשר הפעולה
  action        String // SUBSCRIPTION_CREATE | SUBSCRIPTION_UPGRADE | SUBSCRIPTION_RENEW
  planSelected  String? // ESSENTIAL | PRO | ENTERPRISE
  billingMonths Int? // 1 | 3 | 6 | 12
  amountAgreed  Decimal? @db.Decimal(10, 2) // הסכום שהוסכם

  // פרטי זיהוי (הוכחה חוקית)
  ipAddress String? // כתובת IP
  userAgent String? @db.Text // דפדפן/מכשיר

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([termsType])
}

