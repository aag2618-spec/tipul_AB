// ==================== Payments ====================

model Payment {
  id             String        @id @default(cuid())
  amount         Decimal       @db.Decimal(10, 2) // הסכום ששולם בפועל
  expectedAmount Decimal?      @db.Decimal(10, 2) // הסכום המלא שהיה צריך להשתלם
  paymentType    PaymentType   @default(FULL) // סוג התשלום
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  receiptUrl     String?
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Receipt tracking
  receiptNumber String? // מספר קבלה (לעוסק פטור)
  hasReceipt    Boolean @default(false) // האם הוצאה קבלה

  // Cardcom decline tracking — surfaced to the therapist UI as "ניסיון אחרון נכשל"
  lastDeclineReason String?   @db.Text
  lastDeclineAt     DateTime?

  // Currency — ILS today; column exists so multi-currency work in V2 doesn't
  // require a row-by-row migration on production data.
  currency String @default("ILS")

  // סבב אבטחה 8 (2026-05-18): גרסת ה-receipt token לאימות.
  // 0 = legacy 96-bit (24 hex) — payments שנוצרו לפני שדרוג M4 (2026-05-17).
  // 1 = 128-bit (32 hex) — ברירת מחדל לכל payments חדשים.
  // לפני שדה זה, verifyReceiptToken קיבל גם 24 וגם 32 לכל payment, ותוקף
  // היה יכול לתקוף את הגרסה החלשה (96-bit) גם על payments חדשים.
  receiptTokenVersion Int @default(1)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  sessionId String?         @unique
  session   TherapySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  // Parent-Child relation for partial payments
  parentPaymentId String?
  parentPayment   Payment?  @relation("PaymentChildren", fields: [parentPaymentId], references: [id], onDelete: Cascade)
  childPayments   Payment[] @relation("PaymentChildren")

  // Cardcom — transactions and invoices linked to this payment
  cardcomTransactions CardcomTransaction[]
  cardcomInvoices     CardcomInvoice[]

  // Clinic multi-tenancy
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([parentPaymentId])
  @@index([clientId])
  @@index([status])
  @@index([clientId, status])
  @@index([hasReceipt])
  @@index([organizationId])
  @@index([status, parentPaymentId, paidAt])
  @@index([organizationId, status, parentPaymentId, paidAt(sort: Desc)])
  @@index([organizationId, status, parentPaymentId, createdAt(sort: Desc)])
  @@index([clientId, status, parentPaymentId])
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  BANK_TRANSFER
  CHECK
  CREDIT
  OTHER
}

// Business type for receipt handling
enum BusinessType {
  NONE // לא רוצה קבלות
  EXEMPT // עוסק פטור - קבלות פנימיות
  LICENSED // עוסק מורשה - מחובר למערכת חיצונית
}

// Israeli accounting method:
//   CASH    — מקבל-תשלום: invoice issued at payment time (most freelancers).
//   ACCRUAL — מצטבר: tax invoice at agreement, separate receipt at payment.
enum AccountingMethod {
  CASH
  ACCRUAL
}

// Default receipt mode
enum ReceiptMode {
  ALWAYS // תמיד להוציא קבלה
  ASK // לשאול בכל תשלום
  NEVER // לעולם לא
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentType {
  FULL // תשלום מלא
  PARTIAL // תשלום חלקי
  ADVANCE // תשלום מראש (קרדיט)
}

